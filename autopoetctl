#!/bin/sh
# Terminal control for the running autopoet app. Reads {port, token} from data/ctl
# (written at boot, removed at shutdown — a stale file means a dead app).
DIR="$(cd "$(dirname "$0")" && pwd)"
CTL="$DIR/data/ctl"

[ -f "$CTL" ] || { echo "autopoet not running (no $CTL)"; exit 1; }
read -r PORT TOKEN <"$CTL"
BASE="http://127.0.0.1:$PORT"

case "${1:-status}" in
  status | log | proposals)
    curl -s "$BASE/${1:-status}"
    ;;
  tail)
    curl -sN "$BASE/sse"
    ;;
  arm)
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/arm?every=${2:-15m}"
    ;;
  disarm | close | kill)
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/$1"
    ;;
  accept | reject)
    [ -n "$2" ] || { echo "usage: autopoetctl $1 <proposal-id>"; exit 2; }
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/proposal/$2/$1"
    ;;
  request)
    [ -n "$3" ] || { echo "usage: autopoetctl request <target> <change...>"; exit 2; }
    TARGET="$2"
    shift 2
    curl -s -X POST -H "authorization: Bearer $TOKEN" \
      --data-urlencode "target=$TARGET" --data-urlencode "change=$*" -G "$BASE/request" -X POST
    ;;
  cycle)
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/cycle"
    ;;
  *)
    echo "usage: autopoetctl status|log|tail|proposals|arm [every]|disarm|request <target> <change>|cycle|accept <id>|reject <id>|close|kill"
    exit 2
    ;;
esac
