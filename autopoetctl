#!/bin/sh
# Terminal control for the running autopoet app. Reads {port, token} from data/ctl
# (written at boot, removed at shutdown — a stale file means a dead app).
DIR="$(cd "$(dirname "$0")" && pwd)"
# respect AUTOPOET_HOME so a second instance (venture desk) is addressable:
#   AUTOPOET_HOME=$PWD/venture-home ./autopoetctl proposals
CTL="${AUTOPOET_HOME:-$DIR}/data/ctl"

[ -f "$CTL" ] || { echo "autopoet not running (no $CTL)"; exit 1; }
read -r PORT TOKEN <"$CTL"
BASE="http://127.0.0.1:$PORT"

case "${1:-status}" in
  status | log | proposals | projects | digest)
    curl -s "$BASE/${1:-status}"
    ;;
  signin)
    # open the Workbooks Cloud device-flow login in the browser
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/auth/cloud/open"
    echo "opening Workbooks Cloud login…"
    ;;
  signout)
    # full sign-out: revoke+drop the cloud PAT, clear the local session
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/auth/cloud/signout"
    ;;
  project)
    # project new <slug> [archetype] <prompt...> | status <slug> | archive <slug>
    #         desk-start <slug> | desk-stop <slug>
    SUB="$2"
    case "$SUB" in
      new)
        SLUG="$3"; ARCH="${4:-venture}"; shift 4 2>/dev/null || shift 3
        [ -n "$SLUG" ] || { echo "usage: autopoetctl project new <slug> [archetype] <prompt...>"; exit 2; }
        curl -s -X POST -H "authorization: Bearer $TOKEN" --data-binary "$*" \
          "$BASE/projects/new?slug=$SLUG&archetype=$ARCH"
        ;;
      status)
        curl -s "$BASE/projects/$3/status"
        ;;
      archive)
        curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/projects/$3/archive"
        ;;
      desk-start)
        curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/projects/$3/desk/start"
        ;;
      desk-stop)
        curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/projects/$3/desk/stop"
        ;;
      *)
        echo "usage: autopoetctl project new|status|archive|desk-start|desk-stop ..."; exit 2
        ;;
    esac
    ;;
  tail)
    curl -sN "$BASE/sse"
    ;;
  arm)
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/arm?every=${2:-15m}"
    ;;
  disarm | close | kill)
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/$1"
    ;;
  accept | revert)
    [ -n "$2" ] || { echo "usage: autopoetctl $1 <proposal-id>"; exit 2; }
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/proposal/$2/$1"
    ;;
  reject)
    ID="$2"
    [ -n "$ID" ] || { echo "usage: autopoetctl reject <proposal-id> [reason...]"; exit 2; }
    shift 2
    curl -s -H "authorization: Bearer $TOKEN" --data-urlencode "reason=$*" -G "$BASE/proposal/$ID/reject" -X POST
    ;;
  request)
    [ -n "$3" ] || { echo "usage: autopoetctl request <target> <change...>"; exit 2; }
    TARGET="$2"
    shift 2
    curl -s -X POST -H "authorization: Bearer $TOKEN" \
      --data-urlencode "target=$TARGET" --data-urlencode "change=$*" -G "$BASE/request" -X POST
    ;;
  cycle)
    curl -s -X POST -H "authorization: Bearer $TOKEN" "$BASE/cycle"
    ;;
  research)
    shift
    [ -n "$*" ] || { echo "usage: autopoetctl research <question>"; exit 2; }
    curl -s -H "authorization: Bearer $TOKEN" --data-urlencode "q=$*" -G "$BASE/research" -X POST
    ;;
  limb)
    NAME="$2"
    shift 2
    [ -n "$NAME" ] && [ -n "$*" ] || { echo "usage: autopoetctl limb <name> <task...>"; exit 2; }
    curl -s -H "authorization: Bearer $TOKEN" --data-urlencode "name=$NAME" --data-urlencode "task=$*" -G "$BASE/limb" -X POST
    ;;
  *)
    echo "usage: autopoetctl status|log|tail|proposals|projects|digest|project <new|status|archive|desk-start|desk-stop>|signin|signout|arm [every]|disarm|request|cycle|research|accept <id>|reject <id>|close|kill"
    exit 2
    ;;
esac
