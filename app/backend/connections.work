# Autopoet.Connections

  The local, encrypted home for a user's CONNECTION tokens — the OAuth access

The module verbatim, now authored as `.work` — its Elixir source lives inside
a beam-compiled `server` block instead of a scattered `.ex` file.

server :connections do
defmodule Autopoet.Connections do
  @moduledoc """
  The local, encrypted home for a user's CONNECTION tokens — the OAuth access
  tokens (github/google) and pasted API tokens (cloudflare) that let the intake
  scout and agents read the user's real accounts.

  Distinct from `Nexus.Secrets`, which reads DEPLOY-time credentials (the OAuth
  CLIENT_ID/SECRET, injected via env). Those identify the APP; these identify
  the USER, are minted per-install, and must never touch the cloud store or git.
  So they live at `data/connections/<provider>.tok`, AES-256-GCM encrypted with
  a per-install key at `data/connections/.key` (generated once, 0600). `data/`
  is git-ignored.

  Line-based envelope on disk is impossible (ciphertext is binary), so the file
  is raw `iv <> tag <> ciphertext` — the one place binary-at-rest is correct
  (it's a secret, not config). Everything else stays text.
  """

  @dir_perm 0o700
  @file_perm 0o600

  def dir, do: Path.join([Autopoet.Discovery.home(), "data", "connections"])

  @doc "Store a provider's token (opaque string). Overwrites. Returns :ok."
  def put(provider, token) when is_binary(token) do
    p = provider!(provider)
    File.mkdir_p!(dir())
    File.chmod(dir(), @dir_perm)
    iv = :crypto.strong_rand_bytes(12)
    {ct, tag} = :crypto.crypto_one_time_aead(:aes_256_gcm, key(), iv, token, <<>>, true)
    path = tok_path(p)
    File.write!(path, iv <> tag <> ct)
    File.chmod(path, @file_perm)
    :ok
  end

  @doc "Read a provider's token, or nil if never connected / undecryptable."
  def get(provider) do
    p = provider!(provider)

    with {:ok, <<iv::binary-size(12), tag::binary-size(16), ct::binary>>} <- File.read(tok_path(p)),
         plain when is_binary(plain) <-
           :crypto.crypto_one_time_aead(:aes_256_gcm, key(), iv, ct, <<>>, tag, false) do
      plain
    else
      _ -> nil
    end
  end

  @doc "Is a provider connected (a decryptable token exists)?"
  def connected?(provider), do: get(provider) != nil

  # Featured connection providers. OpenRouter is DEMOTED from the headline group
  # (wb-siutv): AI credits flow through the Workbooks Cloudflare LLM gateway, so
  # a per-user OpenRouter key isn't the default path — it stays available but is
  # not featured. Alpaca joins as the finance/trading connection.
  # featured six FIRST (lifecycle-plan): AgentMail promoted (email built-in),
  # OpenRouter dropped from the front (AI rides the Workbooks gateway);
  # X/Alpaca/Shopify are drawer/second-row.
  @providers ~w(google cloudflare github polar meta agentmail alpaca shopify openrouter)

  @doc "Ordered provider list — first six are the featured tiles."
  def providers, do: @providers

  @doc "All connected providers, for the state endpoint."
  def all, do: for(p <- @providers, connected?(p), do: p)

  @doc "Drop a provider's token."
  def delete(provider), do: File.rm(tok_path(provider!(provider)))

  # ── per-install key ─────────────────────────────────────────────────────────
  # WB_ENV_MASTER_KEY if a deploy injected one (shared-machine identity); else a
  # per-install random key generated once and kept 0600 beside the tokens.
  defp key do
    case Nexus.Secrets.get("WB_ENV_MASTER_KEY") do
      k when is_binary(k) and byte_size(k) >= 32 -> binary_part(k, 0, 32)
      _ -> local_key()
    end
  end

  defp local_key do
    path = Path.join(dir(), ".key")

    case File.read(path) do
      {:ok, k} when byte_size(k) == 32 ->
        k

      _ ->
        File.mkdir_p!(dir())
        File.chmod(dir(), @dir_perm)
        k = :crypto.strong_rand_bytes(32)
        File.write!(path, k)
        File.chmod(path, @file_perm)
        k
    end
  end

  defp tok_path(p), do: Path.join(dir(), "#{p}.tok")

  defp provider!(p) when p in @providers, do: p
  defp provider!(p), do: raise(ArgumentError, "unknown provider: #{inspect(p)}")
end
end
