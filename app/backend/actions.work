# Autopoet.Actions

  The agent's ACTION VOCABULARY (wb-siutv.2) â€” the unified set of things the

The module verbatim, now authored as `.work` â€” its Elixir source lives inside
a beam-compiled `server` block instead of a scattered `.ex` file.

server :actions do
defmodule Autopoet.Actions do
  @moduledoc """
  The agent's ACTION VOCABULARY (wb-siutv.2) â€” the unified set of things the
  brain can DO, from two sources:

    * NATIVE lanes â€” the low-latency core I hand-built: Alpaca (paper trading),
      Google Workspace (Gmail/Calendar/Sheets), GitHub (read/sync). Direct, no
      broker in the path.
    * COMPOSIO â€” the long tail: whatever toolkits the user connected through
      Composio (its 1000+ app catalog), pulled in as function-calling schemas
      and executed via `Composio.execute`. The vocabulary GROWS with whatever
      the user connects, without hand-coding each tool.

  Every action carries a SAFETY class â€” `:safe` (a read or a draft, run
  directly) or `:gated` (an outward/consequential action: send, create, commit,
  delete, an over-cap trade). `invoke/3` runs safe actions and settles the
  result on the bus; gated actions refuse without `confirm: true`, so the brain
  PROPOSES them (through the human gate) instead of firing autonomously â€” the
  cage, applied to every tool.

  `vocabulary/1` is what the brain sees: `[%{name, description, schema, safety,
  source}]`. Composio fetches are injectable (`:composio_source`) for evals.
  """

  alias Autopoet.{Alpaca, Workspace}

  # â”€â”€ the vocabulary â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

  @doc "Everything the brain can do: native lanes ++ connected Composio tools."
  def vocabulary(opts \\ []) do
    (native() ++ composio(opts))
    |> Enum.map(&Map.take(&1, [:name, :description, :schema, :safety, :source]))
  end

  @doc "Find an action spec by name (native first, then Composio)."
  def find(name, opts \\ []) do
    Enum.find(native() ++ composio(opts), &(&1.name == to_string(name)))
  end

  @doc """
  Invoke an action. Safe actions run and settle `action.performed`. Gated
  actions refuse (`{:gated, name}`) unless `confirm: true` â€” the brain proposes
  those. Returns the executor result, `{:gated, name}`, or `{:error, :no_action}`.
  """
  def invoke(name, args, opts \\ []) do
    confirmed? = opts[:confirm] == true

    case find(name, opts) do
      nil ->
        {:error, :no_action}

      %{safety: :gated} = a when not confirmed? ->
        emit("action.proposed", a, :gated)
        {:gated, a.name}

      %{run: run} = a ->
        result = run.(args, opts)
        emit("action.performed", a, status_of(result))
        result
    end
  end

  @doc """
  ROUTE a brain-intended action through the cage: a SAFE action performs now
  (`{:performed, result}`); a GATED action is recorded as a pending PROPOSAL the
  human accepts (`{:proposed, id}`) â€” the brain proposes outward actions, it
  never fires them. `{:error, :no_action}` for an unknown name.
  """
  def route(name, args, opts \\ []) do
    case find(name, opts) do
      nil ->
        {:error, :no_action}

      %{safety: :safe} = a ->
        emit("action.performed", a, :ok)
        {:performed, a.run.(args, opts)}

      %{safety: :gated} = a ->
        emit("action.proposed", a, :gated)

        id =
          Autopoet.Proposals.record(
            %{target: "action:#{a.name}", kind: "action.gated", source: to_string(a.source)},
            %{"action-#{a.name}.txt" => "PROPOSED ACTION (needs your OK): #{a.name}\n#{a.description}\n\nargs:\n#{inspect(args, pretty: true)}\n"}
          )

        {:proposed, id}
    end
  end

  @doc """
  Parse action intents from brain output and route each. Returns the list of
  `{name, routing_result}`.
  """
  def route_intents(text, opts \\ []) when is_binary(text) do
    for {name, args} <- parse_intents(text), do: {name, route(name, args, opts)}
  end

  @doc """
  Parse `=== action: <name> ===` blocks. LIBERAL about the args the LLM wrote
  (live-run finding: brains drift from the requested JSON): accepts a JSON
  object, `key: value` lines, `key = value` lines, or nothing (empty args).
  Numeric-looking values coerce to numbers.
  """
  def parse_intents(text) when is_binary(text) do
    Regex.scan(~r/===\s*action:\s*([a-zA-Z0-9_]+)\s*===[ \t]*\n(.*?)(?=\n?===|\z)/s, text)
    |> Enum.map(fn [_, name, body] -> {String.downcase(name), parse_args(String.trim(body))} end)
  end

  defp parse_args(""), do: %{}

  defp parse_args(body) do
    with [json] <- Regex.run(~r/\{.*\}/s, body),
         {:ok, m} when is_map(m) <- Jason.decode(json) do
      m
    else
      _ ->
        # key: value / key = value lines
        Regex.scan(~r/^\s*([A-Za-z_][A-Za-z0-9_]*)\s*[:=]\s*(.+?)\s*$/m, body)
        |> Map.new(fn [_, k, v] -> {k, coerce(String.trim(v, "\""))} end)
    end
  end

  defp coerce(v) do
    cond do
      Regex.match?(~r/^-?\d+$/, v) -> String.to_integer(v)
      Regex.match?(~r/^-?\d+\.\d+$/, v) -> String.to_float(v)
      true -> v
    end
  end

  # â”€â”€ native lanes â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

  defp native do
    [
      # Alpaca â€” the trading oracle
      act("alpaca_account", "Read the trading account (cash, buying power, equity).", %{}, :safe, :native,
        fn _a, o -> Alpaca.account(o) end),
      act("alpaca_bars", "Recent OHLCV bars for a symbol â€” the market data a trade rests on.",
        %{symbol: "string", timeframe: "string (e.g. 1Day)", limit: "int"}, :safe, :native,
        fn a, o -> Alpaca.bars(a[:symbol] || a["symbol"], o) end),
      act("alpaca_place_order", "Place an order (risk-capped). Buy/sell qty of a symbol.",
        %{symbol: "string", qty: "number", side: "buy|sell", price: "number (for risk sizing)"}, :gated, :native,
        fn a, o -> Alpaca.place_order(atomize(a), o) end),

      # Google Workspace
      act("gmail_list", "List Gmail messages matching a query.", %{query: "string", limit: "int"}, :safe, :native,
        fn a, o -> Workspace.gmail_list(a[:query] || a["query"] || "", o) end),
      act("gmail_read", "Read one Gmail message by id.", %{id: "string"}, :safe, :native,
        fn a, o -> Workspace.gmail_read(a[:id] || a["id"], o) end),
      act("gmail_draft", "Create a Gmail draft (not sent).", %{to: "string", subject: "string", body: "string"}, :safe, :native,
        fn a, o -> Workspace.gmail_draft(atomize(a), o) end),
      act("gmail_send", "SEND an email. Outward â€” gated.", %{to: "string", subject: "string", body: "string"}, :gated, :native,
        fn a, o -> Workspace.gmail_send(atomize(a), Keyword.put(o, :confirm, true)) end),
      act("calendar_list", "List upcoming calendar events.", %{limit: "int"}, :safe, :native,
        fn _a, o -> Workspace.calendar_list(o) end),
      act("calendar_create", "Create a calendar event. Outward â€” gated.",
        %{summary: "string", start_iso: "string", end_iso: "string"}, :gated, :native,
        fn a, o -> Workspace.calendar_create(atomize(a), Keyword.put(o, :confirm, true)) end),
      act("sheet_read", "Read a range from a spreadsheet.", %{sheet_id: "string", range: "string"}, :safe, :native,
        fn a, o -> Workspace.sheet_read(a[:sheet_id] || a["sheet_id"], a[:range] || a["range"], o) end),

      # GitHub
      act("github_read", "Read a file from a repo.", %{repo: "owner/name", path: "string"}, :safe, :native,
        fn a, o -> Workspace.github_read(a[:repo] || a["repo"], a[:path] || a["path"], o) end),
      act("github_commit", "Commit a file to a repo (the sync lane). Outward â€” gated.",
        %{repo: "owner/name", path: "string", content: "string", message: "string"}, :gated, :native,
        fn a, o -> Workspace.github_commit(a[:repo] || a["repo"], a[:path] || a["path"], a[:content] || a["content"], a[:message] || a["message"], Keyword.put(o, :confirm, true)) end)
    ]
  end

  # â”€â”€ Composio: the connected long tail â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

  defp composio(opts) do
    source =
      Keyword.get(opts, :composio_source, fn -> live_composio_tools() end)

    source.()
    |> Enum.map(&composio_action/1)
  rescue
    _ -> []
  end

  # each Composio tool (a function-calling schema) â†’ an action spec; run =
  # Composio.execute. Safety inferred from the verb in the slug.
  defp composio_action(%{} = tool) do
    slug = tool["slug"] || tool["name"] || tool[:slug] || tool[:name]
    fun = get_in(tool, ["function"]) || tool
    desc = tool["description"] || fun["description"] || ""

    %{
      name: to_string(slug),
      description: to_string(desc),
      schema: fun["parameters"] || %{},
      safety: composio_safety(slug),
      source: :composio,
      run: fn args, _o -> Autopoet.Composio.execute(to_string(slug), Map.new(args)) end
    }
  end

  @write_verbs ~w(send create update delete post write publish add remove move merge close archive)
  defp composio_safety(slug) do
    s = String.downcase(to_string(slug))
    if Enum.any?(@write_verbs, &String.contains?(s, &1)), do: :gated, else: :safe
  end

  defp live_composio_tools do
    if Autopoet.Composio.configured?() do
      for %{"slug" => tk} <- connected_toolkits(),
          {:ok, %{"items" => tools}} <- [Autopoet.Composio.tools(tk)],
          tool <- tools do
        tool
      end
    else
      []
    end
  rescue
    _ -> []
  end

  defp connected_toolkits do
    case Autopoet.Composio.connections() do
      {:ok, %{"items" => items}} -> Enum.map(items, fn c -> %{"slug" => c["toolkit"]["slug"] || c["toolkit"]} end) |> Enum.uniq()
      _ -> []
    end
  rescue
    _ -> []
  end

  # â”€â”€ helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

  defp act(name, desc, schema, safety, source, run),
    do: %{name: name, description: desc, schema: schema, safety: safety, source: source, run: run}

  defp atomize(m) do
    Map.new(m, fn
      {k, v} when is_binary(k) -> {String.to_atom(k), v}
      {k, v} -> {k, v}
    end)
  end

  defp status_of({:ok, _}), do: :ok
  defp status_of(_), do: :error

  defp emit(kind, action, status) do
    # carry the action's semantic content as decision context (features), so an
    # `action.proposed` is a training row, not just a name â€” parallels the
    # `proposal.recorded` context.
    ctx = %{desc: action |> Map.get(:description, "") |> to_string() |> String.slice(0, 200)}
    Nexus.Events.emit(%{kind: kind, action: action.name, source: to_string(action.source), status: status, context: ctx, tags: []})
  rescue
    _ -> :ok
  end
end
end
