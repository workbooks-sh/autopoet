# The design system

Every stylesheet the app wears, as `design` blocks — one per concern, ported
faithfully from the app's look. The shell tokens live in the app root; these dress
the surfaces that compose around the cube: the plan conversation, the designer,
the deck, the call bar, the sidebar, the onboarding gate, and the world graph.

## part0

design :part0 do
  :root { --ink:#223; --paper:#fbfbf9; --grid:#e6e8ea; --line:#e3e5e8;
    /* surfaces (paper tiers) */
    --surface:#fff; --surface-2:#fdfdfc; --panel:#f7f7f4; --fill:#f2f4f7;
    --fill-hover:#eef1f8;
    /* the 3D cube avatar. body + features are the CHARACTER's own (theme-independent,
       set inline by applyCharacter); only the toon OUTLINE follows the UI theme. */
    --face-bg:#ffffff; --face-features:#121316; --face-outline:#121316;
    --face-drop:rgba(18,19,22,.10);          /* cube ground shadow */
    /* text tiers (on paper) */
    --ink-2:#3a4250; --ink-muted:#5a6472; --ink-dim:#67707c; --ink-faint:#98a0ac;
    --ink-fainter:#b3bac4;
    /* borders (translucent dividers flip with theme) */
    --border:#e0e4ea; --border-soft:rgba(25,35,55,.08); --border-mid:rgba(25,35,55,.16);
    /* world-graph edges + major grid (JS-drawn, read via var() in SVG attrs) */
    --edge:#e2e6ea; --edge-ref:#b8c4d0; --grid-major:#d8dce0;
    /* the built-in system cluster's reserved gray — a quiet tile the emoji
       reads against (light theme: light gray; dark theme overrides darker) */
    --sys-node:#d7dce1;
    /* elevation */
    --shadow-1:0 1px 3px rgba(25,35,55,.10); --shadow-2:0 8px 30px rgba(25,35,55,.16);
    /* accents / status — hue kept, tuned per theme for legibility */
    --blue:#2f6fdd; --blue-soft:#5b8cc9; --blue-deep:#245cc0;
    --purple:#8e7cc3; --green:#6aa84f; --green-deep:#4d8b3a; --red:#c0392b;
    --amber:#f2a33c; --orange:#d78d1e;
    --on-accent:#fff;            /* text on a saturated accent — same in both themes */
    --ink-strong:#1c2230;        /* near-black chips/pins on light */
    --btn-solid:#2a3140; --btn-solid-hover:#1c2230;   /* solid dark action button */
    /* status tint backgrounds */
    --ok-bg:#e8f5e9; --err-bg:#fdecea; --sel-bg:#e4e8f5;
    /* history-manager tokens — THEME-AWARE: light values here; a dark theme
       overrides just these (the timeline reads only var(--hist-*)) */
    --hist-bg:#f7f7f4; --hist-strip:#efefe9; --hist-strip-line:#e3e5e8;
    --hist-row-hover:#efefe9; --hist-row-sel:#e4e8f5;
    --hist-id:#5b8cc9; --hist-id-head:#c98a1e; --hist-text:#5a6472; --hist-dim:#98a0ac;
    --hist-time:#b3bac4; --hist-vault:#c2569b; --hist-body:#2f6fdd;
    --hist-move:#d78d1e; --hist-merge:#4d8b3a; --hist-now:#f2a33c;
    --hist-btn:#fff; --hist-btn-line:#e3e5e8; --hist-btn-ink:#67707c;
    /* lane palette — vault magenta vs body blue read apart at a glance */
    --hist-lane-0:#2f6fdd; --hist-lane-1:#c2569b; --hist-lane-2:#4d8b3a;
    --hist-lane-3:#d78d1e; --hist-lane-4:#c94f4f; --hist-lane-5:#2a9d94;
    --hist-lane-6:#7a5cc0; }
  :root[data-theme="dark"] {
    --ink:#e4e7ec; --paper:#101318; --grid:#262c35; --line:#262c35;
    --surface:#171a20; --surface-2:#1b1f26; --panel:#14171c; --fill:#1b1f26;
    --fill-hover:#20262f;
    --face-outline:#e8ebf0;   /* dark theme: only the cube outline flips to white */
    --face-drop:rgba(0,0,0,.66);
    --ink-2:#c3ccd6; --ink-muted:#aab6c2; --ink-dim:#8a95a2; --ink-faint:#5f6a76;
    --ink-fainter:#4d5763;
    --border:#2b323c; --border-soft:rgba(220,230,245,.08); --border-mid:rgba(220,230,245,.15);
    --edge:#2f3742; --edge-ref:#41505f; --grid-major:#242a33;
    --sys-node:#333a43;
    --shadow-1:0 1px 3px rgba(0,0,0,.45); --shadow-2:0 10px 34px rgba(0,0,0,.55);
    --blue:#6a9ae0; --blue-soft:#7fa8d8; --blue-deep:#5b8cc9;
    --purple:#a99bd6; --green:#7cb861; --green-deep:#6aa84f; --red:#d96a6a;
    --amber:#f2a33c; --orange:#f2a33c;
    --ink-strong:#e4e7ec;
    --btn-solid:#2b323c; --btn-solid-hover:#353d49;
    --ok-bg:#17251b; --err-bg:#2a1a1a; --sel-bg:#20262f;
    --hist-bg:#14171c; --hist-strip:#1b1f26; --hist-strip-line:#262c35;
    --hist-row-hover:#1a1e25; --hist-row-sel:#20262f;
    --hist-id:#5b8cc9; --hist-id-head:#e8cb7a; --hist-text:#aab6c2; --hist-dim:#5f6a76;
    --hist-time:#4d5763; --hist-vault:#d98ac2; --hist-body:#7fa8d8;
    --hist-move:#f2a33c; --hist-merge:#7cb861; --hist-now:#e8cb7a;
    --hist-btn:#20252d; --hist-btn-line:#313947; --hist-btn-ink:#aab6c2;
    --hist-lane-0:#5b8cc9; --hist-lane-1:#c88bc0; --hist-lane-2:#7cb861;
    --hist-lane-3:#f2a33c; --hist-lane-4:#d96a6a; --hist-lane-5:#3aa8a0;
    --hist-lane-6:#8e7cc3; }
  html,body { margin:0; height:100%; overflow:hidden;
    font:13px/1.5 ui-monospace,SFMono-Regular,monospace; color:var(--ink);
    background:var(--paper); }

  #app { display:grid; height:100vh;
    grid-template-columns:var(--tree-w,280px) 0px 1fr;
    grid-template-rows:1fr var(--cons-h,30px);
    transition:grid-template-columns .32s cubic-bezier(.22,.9,.24,1),
               grid-template-rows .28s cubic-bezier(.22,.9,.24,1); }
  #app.editing { grid-template-columns:var(--tree-w,280px) var(--ed-w,480px) 1fr; }
  #app.dragging { transition:none; }   /* 1:1 tracking while a handle is held */

  /* resize handles */
  .rs { position:absolute; top:0; bottom:0; right:-3px; width:6px; cursor:col-resize; z-index:8; }
  .rs:hover { background:rgba(80,120,220,.18); }
  /* the console resize handle exists ONLY when the console is open (collapsed = no grip) */
  #consgrip { display:none; position:absolute; left:0; right:0; top:-3px; height:6px; cursor:row-resize; z-index:8; }
  #app.console-open #consgrip { display:block; }
  #consgrip:hover { background:rgba(80,120,220,.25); }

end

## vault tree green in the mock

design :vault_tree_green_in_the_mock do
  /* ── vault tree (green in the mock) ─────────────────────────────────── */
  #tree { grid-row:1; grid-column:1; border-right:1px solid var(--line);
    background:var(--panel); overflow:hidden; padding:52px 0 0; position:relative;
    display:flex; flex-direction:column; }
  #tree > #treeroot { flex:1 1 auto; overflow:auto; min-height:0; }
  /* the floating top strip: [save prompt when dirty] [chat|voice], packed to the
     RIGHT edge; left:66px reserves the macOS stoplight zone so nothing ever
     overlaps the traffic lights in frameless mode */
  #toprow { position:absolute; top:7px; left:66px; right:8px; z-index:11;
    display:flex; align-items:center; justify-content:flex-end; gap:7px;
    -webkit-app-region:no-drag; }
  /* while the save prompt is up, the comm buttons drop their labels so the
     strip always fits the narrowest sidebar */
  #modetoggle.saving ~ #commtop .lbl { display:none; }
  /* undo/redo/merge — they live in the HISTORY console header now (the timeline
     is the thing they navigate) */
  #histbtns { display:flex; gap:3px; margin-left:6px; }
  #histbtns button { border:1px solid var(--line); background:var(--surface); color:var(--ink-dim);
    border-radius:7px; padding:3px 7px; cursor:pointer; display:flex; align-items:center;
    gap:5px; font:10px ui-monospace,monospace;
    transition:background .15s ease, color .15s ease; -webkit-app-region:no-drag; }
  #histbtns button:hover:not(:disabled) { background:var(--fill-hover); color:var(--ink); }
  #histbtns button:disabled { opacity:.35; cursor:default; }
  #histbtns svg.lucide { width:13px; height:13px; }
  /* the combine-branches prompt only exists while the timeline is actually split */
  #domerge { color:var(--green-deep); border-color:var(--ok-bg); }
  #domerge:hover { background:var(--ok-bg) !important; color:var(--green-deep) !important; }
  /* the vault action toolbar — one row of VS Code Material icons, each carrying a
     + badge so every button clearly reads as "add" (file / sketch / folder / workspace) */
  #vaultbar { flex:none; display:flex; justify-content:center; gap:6px; padding:9px 10px;
    margin-bottom:4px; border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
  #vaultbar .add { position:relative; display:flex; align-items:center; justify-content:center;
    width:32px; height:32px; border:1px solid var(--line); background:var(--surface); border-radius:9px;
    cursor:pointer; transition:background .15s ease, border-color .15s ease; }
  #vaultbar .add:hover { background:var(--fill-hover); border-color:var(--border); }
  #vaultbar .add .mic { width:18px; height:18px; }
  #vaultbar .add .wshash { font:800 16px ui-monospace,monospace; color:var(--purple); line-height:1; }
  #vaultbar .add .pl { position:absolute; right:-4px; bottom:-4px; width:14px; height:14px;
    background:var(--fill); color:var(--ink-faint); border:1.5px solid var(--panel); border-radius:50%;
    font:800 10px ui-monospace,monospace; line-height:1;
    display:flex; align-items:center; justify-content:center; }
  #vaultbar .add:hover .pl { background:var(--line); color:var(--ink-faint); }
  #tree .hd { display:flex; align-items:center; gap:6px; padding:2px 10px 8px;
    color:var(--ink-faint); font-size:11px; }
  #tree .hd b { flex:1; font-weight:600; letter-spacing:.06em; }
  #tree .hd button { border:none; background:none; cursor:pointer; padding:3px;
    border-radius:6px; display:flex; align-items:center; color:var(--ink-dim);
    transition:background .15s ease, color .15s ease; }
  #tree .hd button:hover { background:var(--line); color:var(--ink-2); }
  #tree .hd button svg { width:15px; height:15px; }
  #tree svg.lucide { width:14px; height:14px; flex:none; }
  #tree .tw { display:flex; margin-left:-4px; transition:transform .18s ease; color:var(--ink-faint); }
  #tree .tw svg.lucide { width:12px; height:12px; }
  #tree .row.openf .tw { transform:rotate(90deg); }
  #tree ul.hide { display:none; }
  .ic-folder { color:var(--amber); } .ic-note { color:var(--blue-soft); } .ic-sketch { color:var(--purple); }
  /* a workspace = a #-prefixed grouping (like a folder, but a named group of notes) */
  #tree .row.wsrow { margin-top:5px; font-weight:600; color:var(--ink-muted); letter-spacing:.02em; }
  /* the # is GRAY (folder-tone) everywhere so a composed badge has consistent contrast */
  .hashtag { color:var(--ink-faint); font-weight:800; flex:none; display:inline-flex;
    align-items:center; justify-content:center; font-family:ui-monospace,monospace; line-height:1; }
  #tree .row.wsrow .hashtag { width:13px; }
  /* the composed badge overhangs its box to the right — reserve gap so it doesn't
     crowd the label (the # badge sits further right, so it needs a touch more) */
  #tree .composed { margin-right:5px; }
  #tree .wsrow .composed { margin-right:9px; }
  /* composed icon: base (folder shape / gray #) + a picked icon badged bottom-right.
     the badge gets a drop-shadow HALO that follows the SVG's own alpha shape (a
     "sticker" outline) — not a boxy square — so it cuts cleanly out of the base. */
  .composed { position:relative; display:inline-flex; align-items:center; flex:none; }
  .composed .cbadge { position:absolute; right:-3px; bottom:-3px; display:inline-flex;
    align-items:center; justify-content:center; }
  /* the # is narrow — push its badge further right so the # shape stays visible */
  .composed .cbadge-ws { right:-7px; }
  /* OUTER: runs the grow/smooth filter on the masked child (filter must wrap the mask) */
  .composed .cbadge .cmask { position:absolute; inset:0; filter:url(#goo); }
  /* INNER: the icon's alpha masks a solid fill of the surrounding colour = silhouette */
  .composed .cbadge .csil { position:absolute; inset:0; background:var(--panel);
    -webkit-mask-repeat:no-repeat; mask-repeat:no-repeat;
    -webkit-mask-position:center; mask-position:center;
    -webkit-mask-size:contain; mask-size:contain; }
  .composed .cbadge img { position:relative; display:block; }
  /* IDE-style dirty marker on unsaved files */
  #tree .row.isdirty::after { content:"●"; color:var(--amber); font-size:9px; margin-left:auto; }
  #tree ul { list-style:none; margin:0; padding-left:14px; }
  #tree > ul { padding-left:6px; }
  #tree li > .row { display:flex; align-items:center; gap:6px; padding:2px 6px;
    border-radius:5px; cursor:pointer; white-space:nowrap; }
  #tree li > .row:hover { background:#ececе6; background:var(--fill); }
  #tree li > .row.open { background:var(--sel-bg); }
  #tree img.mic { width:16px; height:16px; flex:none; }   /* VS Code material icons */

end

## prose sketch editor blue in the mock

design :prose_sketch_editor_blue_in_the_mock do
  /* ── prose / sketch editor (blue in the mock) ───────────────────────── */
  #editor { grid-row:1; grid-column:2; border-right:1px solid var(--line);
    display:none; flex-direction:column; background:var(--surface); min-width:0; position:relative;
    opacity:0; transform:translateX(-8px);
    transition:opacity .28s ease .1s, transform .28s cubic-bezier(.22,.9,.24,1) .1s; }
  #app.editing #editor { opacity:1; transform:none; }
  #app.editing #editor { display:flex; }
  #editor .hd { display:flex; align-items:center; gap:9px; padding:9px 14px;
    color:var(--ink-2); font-size:12px; border-bottom:1px solid var(--line); background:var(--paper); }
  #editor .hd .name { cursor:text; }
  #editor .hd .name { flex:1; overflow:hidden; text-overflow:ellipsis; }
  #editor .hd .dot { width:8px; height:8px; border-radius:50%; background:var(--border); }
  #editor .hd .dot.dirty { background:var(--amber); }
  #editor .hd .dot.saved { background:var(--green); }
  #editor .hd button { font:inherit; border:none; background:none; cursor:pointer; color:var(--ink-faint);
    display:flex; padding:3px; border-radius:6px; transition:background .15s ease, color .15s ease; }
  #editor .hd button:hover { background:var(--surface-2); color:var(--ink-2); }
  #editor .hd svg.lucide { width:14px; height:14px; }
  #prose { flex:1; border:none; outline:none; resize:none; padding:18px 20px;
    font:14px/1.7 -apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; color:var(--ink);
    background:var(--surface); }
  /* ── the sketch surface: MS-Paint bones, our theme ─────────────────────── */
  #skwrap { flex:1; display:none; min-height:0; }
  #app.sketching #skwrap { display:flex; }
  #app.sketching #prose { display:none; }
  #skpal { width:46px; flex:none; border-right:1px solid var(--line); background:var(--panel);
    padding:10px 8px; display:flex; flex-direction:column; gap:12px; overflow:auto; }
  #skpal .tools { display:grid; grid-template-columns:1fr; gap:5px; }
  #skpal .tools button { aspect-ratio:1; display:flex; align-items:center; justify-content:center;
    border:1px solid var(--border); border-radius:6px; background:var(--surface-2); cursor:pointer; color:var(--ink-muted);
    box-shadow:inset 0 1px 0 rgba(255,255,255,.9), 0 1px 2px rgba(20,30,50,.06); }
  #skpal .tools button:hover { color:var(--ink); }
  #skpal .tools button.sel { background:var(--sel-bg); color:var(--blue); border-color:var(--border);
    box-shadow:inset 0 1px 3px rgba(30,50,90,.18); }   /* sunken = selected, Paint-style */
  #skpal svg.lucide { width:15px; height:15px; }
  #skpal .sizes { display:flex; flex-direction:column; gap:4px; }
  #skpal .sizes button { display:flex; align-items:center; justify-content:center; height:20px;
    border:1px solid var(--border); border-radius:5px; background:var(--surface-2); cursor:pointer; }
  #skpal .sizes button span { display:block; width:60%; border-radius:99px; background:var(--ink-muted); }
  #skpal .sizes button.sel { background:var(--sel-bg); border-color:var(--border); }
  #skpal .sizes button.sel span { background:var(--blue); }
  #skpal .swatches { display:grid; grid-template-columns:1fr; gap:5px; }
  #skpal .swatches button { aspect-ratio:1; border-radius:6px; cursor:pointer;
    border:1px solid rgba(0,0,0,.15); }
  #skpal .swatches button.sel { outline:2px solid var(--blue); outline-offset:1px; }
  #skundo { grid-column:1 / -1; aspect-ratio:auto !important; height:26px; }
  #sketch { flex:1; touch-action:none; cursor:crosshair; background:var(--surface); min-width:0; }
  #sktext { position:absolute; z-index:9; display:none; font:16px -apple-system,sans-serif;
    border:1px solid var(--blue-soft); border-radius:6px; padding:2px 8px; outline:none; background:var(--surface); }

end

## the world graph

design :the_world_graph do
  /* ── the world (graph) ──────────────────────────────────────────────── */
  #stage { grid-row:1; grid-column:3; position:relative; min-width:0; }
  #graph { position:absolute; inset:0; width:100%; height:100%; cursor:grab; }
  #graph:active { cursor:grabbing; }
  text.lbl { font:11px ui-monospace,monospace; fill:var(--ink-2); pointer-events:none; }

  /* ── console footer: collapsed by default, designed in-theme ─────────── */
  #consolewrap { grid-row:2; grid-column:1 / -1; position:relative;
    border-top:1px solid var(--line); background:var(--panel); color:var(--ink-2);
    display:flex; flex-direction:column; min-height:0; }
  #conshead { display:flex; align-items:center; gap:8px; padding:5px 14px;
    font-size:11px; color:var(--ink-dim); cursor:pointer; user-select:none; flex:none;
    transition:background .15s ease; }
  #conshead:hover { background:var(--fill); }
  #conshead svg.lucide { width:13px; height:13px; }
  #conshead .chev { transition:transform .25s cubic-bezier(.22,.9,.24,1); display:flex; }
  #app.console-open #conshead .chev { transform:rotate(90deg); }
  #conshead .ttl { font-weight:600; letter-spacing:.05em; }
  #conshead .pulse { width:6px; height:6px; border-radius:50%; background:var(--border);
    transition:background .2s ease, box-shadow .2s ease; }
  #conshead .pulse.live { background:var(--green); box-shadow:0 0 0 3px rgba(106,168,79,.18); }
  #conshead .last { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
    color:var(--ink-faint); transition:color .3s ease; }
  #conshead .last.fresh { color:var(--ink-2); }
  #conshead .count { color:var(--ink-fainter); font-size:10px; }
  /* the console IS the history manager: a jj commit DAG rendered like a
     git-graph in a terminal — mono pane, colored lanes, clickable nodes.
     Every color is a --hist-* token, so it follows the app theme. */
  #console { flex:1; overflow:auto; margin:0; padding:0;
    font-size:11px; line-height:1.7; color:var(--hist-text); background:var(--hist-bg);
    opacity:0; transition:opacity .25s ease .08s; pointer-events:none; }
  #app.console-open #console { opacity:1; pointer-events:auto; }
  #histsel { position:sticky; top:0; z-index:2; display:none; align-items:center; gap:8px;
    padding:4px 12px; background:var(--hist-strip); border-bottom:1px solid var(--hist-strip-line);
    color:var(--hist-text); font-size:10.5px; white-space:nowrap; overflow:hidden; }
  #histsel.on { display:flex; }
  #histsel .rid { color:var(--hist-move); font-weight:700; }
  #histsel .rdesc { overflow:hidden; text-overflow:ellipsis; color:var(--hist-text); }
  #histsel .rfiles { flex:1; overflow:hidden; text-overflow:ellipsis; color:var(--hist-dim); }
  #histsel button { border:1px solid var(--hist-btn-line); background:var(--hist-btn);
    color:var(--hist-btn-ink); border-radius:6px; padding:2px 8px; cursor:pointer;
    font:10px ui-monospace,monospace; display:flex; align-items:center; gap:4px; }
  #histsel button:hover { background:var(--hist-row-sel); color:var(--ink); }
  #histsel svg.lucide { width:11px; height:11px; }
  #histwrap { position:relative; padding:6px 0 12px; min-height:100%; box-sizing:border-box; }
  /* the graph paints ABOVE the row hover/selection washes (the node color +
     shape carry meaning — never mask them), but never eats their clicks */
  #histsvg { position:absolute; top:6px; left:0; display:block; z-index:1; pointer-events:none; }
  #histrows { position:relative; }
  .hrow { display:flex; align-items:center; gap:9px; height:22px; padding-right:12px;
    white-space:nowrap; cursor:pointer; animation:lnin .25s ease; }
  .hrow:hover { background:var(--hist-row-hover); }
  .hrow.sel { background:var(--hist-row-sel); }
  .hrow .hid { color:var(--hist-id); flex:none; font-weight:600; }
  .hrow .hdesc { overflow:hidden; text-overflow:ellipsis; color:var(--hist-text); }
  .hrow .hdesc.k-vault { color:var(--hist-vault); }   /* vault = guide purple */
  .hrow .hdesc.k-body { color:var(--hist-body); }     /* body  = note blue    */
  .hrow .hdesc.k-move { color:var(--hist-move); }     /* undo/redo jumps      */
  .hrow .hdesc.k-merge { color:var(--hist-merge); }   /* merges = link green  */
  .hrow .hdesc.k-now { color:var(--hist-dim); font-style:italic; }
  .hrow .htime { margin-left:auto; color:var(--hist-time); flex:none; font-size:10px; }
  .hrow.head .hid { color:var(--hist-id-head); }
  #histempty { padding:14px; color:var(--hist-dim); font-style:italic; }
  @keyframes lnin { from { opacity:0; transform:translateY(3px); } }

  /* node details panel */
  #panel { position:fixed; bottom:44px; right:16px; width:340px; max-height:52vh;
    overflow:auto; overscroll-behavior:contain;
    background:var(--surface); border:1px solid var(--border); border-radius:10px;
    padding:14px; box-shadow:0 6px 24px rgba(0,0,0,.08); display:none; z-index:6; }
  #panel .pencil { float:right; border:none; background:none; cursor:pointer;
    color:var(--ink-faint); padding:3px; border-radius:6px; }
  #panel .pencil:hover { color:var(--ink); background:var(--fill); }
  #panel .pencil svg.lucide { width:14px; height:14px; }

  /* voice grounding: what the autopoet is talking about lights up */
  .ground-ring { fill:none; stroke:var(--amber); stroke-width:2.5; pointer-events:none;
    animation:groundpulse 1.4s ease infinite; }
  @keyframes groundpulse { 0%,100% { stroke-opacity:.95; } 50% { stroke-opacity:.25; } }
  #tree .row.grounded { background:var(--ok-bg); box-shadow:inset 0 0 0 1px var(--amber); }
  #panel h3 { margin:0 0 6px; font-size:13px; word-break:break-all; }
  #panel pre { white-space:pre-wrap; word-break:break-word; font-size:11px; color:var(--ink-2); }
  #panel .tag { display:inline-block; padding:1px 8px; border-radius:99px;
    font-size:10px; color:var(--on-accent); margin-bottom:8px; }
  /* the system cluster's tag rides the quiet theme gray — accent-white fails there */
  #panel .tag.sys { color:var(--ink); }
  #panel button { font:inherit; padding:3px 12px; cursor:pointer; margin-right:6px;
    border-radius:6px; border:1px solid var(--border); background:var(--surface); }
  #panel button.ok { background:var(--ok-bg); } #panel button.no { background:var(--err-bg); }

end

## new in vault modal ours in theme lig

design :new_in_vault_modal_ours_in_theme_lig do
  /* ── new-in-vault modal (ours, in-theme) — LIGHT frosted backdrop, per-kind form ── */
  #shade { position:fixed; inset:0; background:rgba(247,247,244,.5); backdrop-filter:blur(6px);
    -webkit-backdrop-filter:blur(6px); z-index:20; display:none; opacity:0; transition:opacity .2s ease; }
  #shade.on { display:block; opacity:1; }
  #modal { position:fixed; z-index:21; top:16vh; left:50%; width:360px;
    transform:translateX(-50%) translateY(8px) scale(.98); opacity:0; display:none;
    background:var(--surface); border:1px solid var(--line); border-radius:14px;
    box-shadow:0 18px 48px rgba(25,35,55,.14); padding:16px;
    transition:opacity .22s ease, transform .22s cubic-bezier(.22,.9,.24,1); }
  #modal.on { display:block; opacity:1; transform:translateX(-50%) translateY(0) scale(1); }
  #modal h3 { margin:0 0 10px; font-size:12px; letter-spacing:.06em; color:var(--ink-faint); font-weight:600; }
  /* header: icon button + title */
  #modal .mhd { display:flex; align-items:center; gap:11px; margin-bottom:12px; }
  #modal .iconbtn { display:flex; align-items:center; justify-content:center; width:44px; height:44px;
    border:1px solid var(--line); border-radius:12px; background:var(--surface-2); cursor:pointer;
    transition:border-color .15s ease, background .15s ease; flex:none; }
  #modal .iconbtn:hover { border-color:var(--border); background:var(--fill); }
  #modal .mtitle { font-weight:600; font-size:15px; color:var(--ink-2); }
  /* destination breadcrumb */
  #modal .destbc { display:flex; align-items:center; gap:6px; width:100%; box-sizing:border-box;
    padding:6px 9px; margin-bottom:10px; border:1px dashed var(--line); border-radius:8px;
    background:var(--surface-2); color:var(--ink-dim); font:inherit; font-size:11.5px; cursor:pointer;
    transition:border-color .15s ease, color .15s ease; }
  #modal .destbc:hover { border-color:var(--border); color:var(--ink-2); }
  #modal .destbc > span { flex:1; text-align:left; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  #modal .destbc svg.lucide { width:13px; height:13px; flex:none; color:var(--ink-faint); }
  #modal input { width:100%; box-sizing:border-box; margin:0 0 11px; padding:8px 11px;
    font:inherit; font-size:13px; border:1px solid var(--line); border-radius:9px; outline:none; }
  #modal input:focus { border-color:var(--blue-soft); }
  /* labelled rows (type, tags) */
  #modal .mrow { display:flex; align-items:flex-start; gap:10px; margin-bottom:11px; }
  #modal .mrow .ml { width:38px; flex:none; font-size:11px; color:var(--ink-faint); padding-top:7px; letter-spacing:.04em; }
  /* type = two cards, each with an icon + one-line explanation */
  #modal .typecards { display:flex; gap:8px; margin-bottom:11px; }
  #modal .tycard { flex:1; display:flex; gap:8px; align-items:flex-start; text-align:left;
    padding:9px 10px; border:1px solid var(--line); border-radius:10px; background:var(--surface); cursor:pointer;
    transition:border-color .15s ease, background .15s ease; }
  #modal .tycard:hover { border-color:var(--border); }
  #modal .tycard.sel { border-color:var(--blue-soft); background:var(--fill-hover); }
  #modal .tycard svg.lucide { width:16px; height:16px; flex:none; color:var(--blue-soft); margin-top:1px; }
  #modal .tyt { font-weight:600; font-size:12px; color:var(--ink-2); }
  #modal .tyd { font-size:10.5px; color:var(--ink-faint); line-height:1.35; margin-top:2px;
    font-family:-apple-system,BlinkMacSystemFont,sans-serif; }
  /* tags input */
  #modal .tagbox { flex:1; display:flex; flex-wrap:wrap; gap:5px; align-items:center;
    border:1px solid var(--line); border-radius:9px; padding:5px 7px; min-height:20px; }
  #modal .tagbox .tag { display:inline-flex; align-items:center; gap:4px; font-size:11px;
    background:var(--fill-hover); color:var(--ink-2); border-radius:6px; padding:2px 4px 2px 7px; }
  #modal .tagbox .tag b { cursor:pointer; color:var(--ink-faint); font-weight:400; font-size:13px; }
  #modal .tagbox .tag b:hover { color:var(--red); }
  #modal .tagbox input { flex:1; min-width:70px; margin:0; padding:2px; border:none; font-size:12px; }
  #modal .acts { display:flex; justify-content:flex-end; gap:8px; margin-top:4px; }
  #modal .acts button { font:inherit; font-size:12px; padding:7px 15px; border-radius:9px;
    border:1px solid var(--line); background:var(--surface); color:var(--ink-dim); cursor:pointer; }
  #modal .acts .go { background:var(--blue); color:var(--on-accent); border-color:var(--blue); font-weight:600; }
  #modal .acts .go:hover { background:var(--blue-deep); }
  /* shared popup: destination list + icon picker */
  #iconpop { position:fixed; z-index:22; }
  #iconpop.destpop, #iconpop.iconpicker { background:var(--surface); border:1px solid var(--line);
    border-radius:11px; box-shadow:0 14px 38px var(--border-mid); padding:7px; }
  #iconpop .dlist { display:flex; flex-direction:column; gap:2px; max-height:300px; overflow:auto; min-width:200px; }
  #iconpop .ditem { text-align:left; font:inherit; font-size:12px; white-space:pre; padding:6px 9px;
    border:none; background:none; border-radius:7px; cursor:pointer; color:var(--ink-2); }
  #iconpop .ditem:hover { background:var(--fill); }
  #iconpop .ditem.sel { background:var(--fill-hover); color:var(--ink-2); font-weight:600; }
  #iconpop .isearch { width:216px; box-sizing:border-box; margin:0 0 6px; padding:7px 10px;
    font:inherit; font-size:12px; border:1px solid var(--line); border-radius:8px; outline:none; }
  #iconpop .igrid { display:grid; grid-template-columns:repeat(7, 1fr); gap:2px;
    width:230px; max-height:260px; overflow:auto; }
  #iconpop .icell { display:flex; align-items:center; justify-content:center; width:30px; height:30px;
    border:1px solid transparent; border-radius:7px; background:none; cursor:pointer; }
  #iconpop .icell:hover { background:var(--fill); }
  #iconpop .icell.sel { border-color:var(--blue-soft); background:var(--fill-hover); }
  #iconpop .icell img { width:18px; height:18px; }
  /* @-mention popup in the editor */
  #mention { position:fixed; z-index:30; display:none; background:var(--surface); border:1px solid var(--line);
    border-radius:10px; box-shadow:0 12px 34px var(--border-mid); padding:5px; min-width:200px; max-width:280px; }
  #mention.on { display:block; }
  #mention .mitem { display:flex; align-items:center; gap:8px; width:100%; text-align:left;
    padding:6px 8px; border:none; background:none; border-radius:7px; cursor:pointer; color:var(--ink-2); }
  #mention .mitem.sel, #mention .mitem:hover { background:var(--fill-hover); }
  #mention .mitem .mn { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-size:12.5px; }
  #mention .mitem .mk { font-size:10px; color:var(--ink-fainter); }
  #mention .mitem svg.lucide, #mention .mitem img.mic { width:15px; height:15px; flex:none; }
  #mention .mitem .composed { flex:none; }
  /* program/context glyph, right of a file's name */
  #tree .tymark { width:12px; height:12px; flex:none; margin-left:6px; }
  #tree .tymark.ty-program { color:var(--ink-faint); }
  #tree .tymark.ty-context { color:var(--amber); }
  /* tree tag chips */
  #tree .rtags { display:inline-flex; gap:3px; margin-left:6px; }
  #tree .rtag { font-size:9px; color:var(--purple); background:var(--fill); border-radius:4px; padding:0 4px; line-height:15px; }

end

## the save prompt command only now liv

design :the_save_prompt_command_only_now_liv do
  /* ── the save prompt: command-only now (live is gone) — the revert/✓ pair
     pops into the top strip while anything is dirty, vanishes when clean ─── */
  #modetoggle { position:relative; display:grid; align-items:center; -webkit-app-region:no-drag; }
  #modetoggle > * { grid-area:1 / 1; transition:opacity .22s ease, transform .25s cubic-bezier(.22,.9,.24,1); }
  #modetoggle:not(.saving) .saveseg { opacity:0; transform:scale(.92) translateY(3px); pointer-events:none; }
  #modetoggle .saveseg { display:flex; gap:4px; justify-self:end; }
  #modetoggle .saveseg button { border:1px solid var(--line);
    background:var(--surface); color:var(--ink-dim); border-radius:9px; padding:7px 10px; cursor:pointer;
    display:flex; align-items:center; }
  #modetoggle .saveseg svg.lucide { width:14px; height:14px; }
  #modetoggle .saveseg button:hover { color:var(--ink); }
  #modetoggle .saveseg .save { background:var(--blue); border-color:var(--blue); color:var(--on-accent); }
  #modetoggle .saveseg .save:hover { background:var(--blue-deep); color:var(--on-accent); }
  #modetoggle .saveseg kbd { background:rgba(255,255,255,.22); border-radius:4px; padding:0 4px; font:inherit; }

  /* ── comm switcher: chat/voice lives at the sidebar's foot, above the account
     row — the frameless window chrome was overlapping (and eating clicks on)
     its old top-strip spot ── */
  #commtop { display:flex; gap:4px; background:var(--surface); border:1px solid var(--line);
    border-radius:10px; padding:3px; margin:0 10px 6px; }
  #commtop button { flex:1; }
  #commtop button { display:flex; align-items:center; justify-content:center; gap:5px;
    font:11px ui-monospace,monospace; border:none; background:none; color:var(--ink-dim);
    border-radius:8px; padding:5px 9px; cursor:pointer;
    transition:background .18s ease, color .18s ease; }
  #commtop button:hover { color:var(--ink); background:var(--fill); }
  /* selected keeps its color on hover — just a shade lighter (never white-on-white) */
  #comm-chat.sel, #comm-chat.sel:hover { color:var(--on-accent); }
  #comm-voice.sel, #comm-voice.sel:hover { color:var(--on-accent); }
  #comm-chat.sel { background:var(--purple); }          /* chat = the graph's guide purple */
  #comm-chat.sel:hover { background:var(--purple); }
  #comm-voice.sel { background:var(--green); }         /* voice = link green */
  #comm-voice.sel:hover { background:var(--green); }
  #commtop svg.lucide { width:13px; height:13px; }

  /* ── chat panel: shares the column-2 slot with files (one or the other) ── */
  #app.chatting { grid-template-columns:var(--tree-w,280px) var(--ed-w,480px) 1fr; }
  #chatpanel { grid-row:1; grid-column:2; border-right:1px solid var(--line);
    display:none; flex-direction:column; background:var(--surface); min-width:0; position:relative;
    opacity:0; transform:translateX(-8px);
    transition:opacity .28s ease .1s, transform .28s cubic-bezier(.22,.9,.24,1) .1s; }
  #app.chatting #chatpanel { display:flex; opacity:1; transform:none; }
  #app.chatting #editor { display:none !important; }
  #chatpanel .hd { display:flex; align-items:center; gap:9px; padding:9px 14px;
    color:var(--ink-2); font-size:12px; border-bottom:1px solid var(--line); background:var(--paper); }
  #chatpanel .hd .ttl { flex:1; font-weight:600; }
  #chatpanel .hd button { border:none; background:none; cursor:pointer; color:var(--ink-faint);
    display:flex; padding:3px; border-radius:6px; transition:background .15s ease, color .15s ease; }
  #chatpanel .hd button:hover { background:var(--surface-2); color:var(--ink-2); }
  #chatpanel .hd svg.lucide { width:14px; height:14px; }
  #chatlog { flex:1; overflow:auto; padding:14px; display:flex; flex-direction:column; gap:10px; }
  #chatlog .m { max-width:86%; padding:8px 12px; border-radius:14px; font-size:13px;
    line-height:1.55; white-space:pre-wrap; word-break:break-word;
    font-family:-apple-system,BlinkMacSystemFont,sans-serif; animation:lnin .22s ease; }
  #chatlog .m.user { align-self:flex-end; background:var(--ink); color:var(--fill); border-bottom-right-radius:5px; }
  #chatlog .m.ap { align-self:flex-start; background:var(--fill); color:var(--ink-2); border-bottom-left-radius:5px; }
  #chatlog .m.ap .ref { color:var(--blue); }
  #chatlog .m .blk { display:block; background:var(--surface); border:1px solid var(--line); border-radius:8px;
    padding:8px 10px; margin:6px 0; font:11px ui-monospace,monospace; overflow-x:auto; }
  #chatlog .typing { align-self:flex-start; color:var(--ink-faint); font-size:11px; padding:2px 6px; }
  #chatsessions { flex:1; overflow:auto; padding:10px; display:none; }
  #chatpanel.sessions #chatlog, #chatpanel.sessions #composer { display:none; }
  #chatpanel.sessions #chatsessions { display:block; }
  #chatsessions .sess { padding:9px 12px; border:1px solid var(--line); border-radius:9px;
    margin-bottom:7px; cursor:pointer; font-size:12px; }
  #chatsessions .sess:hover { background:var(--panel); }
  #chatsessions .sess .id { color:var(--ink-faint); font-size:10px; }
  /* the composer (ported from the cloud studio Composer): card = textarea over
     an inline toolbar; floating @ / pickers; emoji popover; activating send */
  #composer { display:block; padding:10px 12px; border-top:1px solid var(--line);
    background:var(--paper); position:relative; }
  #composer .card { border:1px solid var(--line); border-radius:16px; background:var(--surface);
    transition:border-color .15s ease; }
  #composer .card:focus-within { border-color:var(--blue-soft); }
  #composer textarea { width:100%; box-sizing:border-box; resize:none; border:none;
    outline:none; background:none; padding:11px 13px 4px;
    font:13.5px/1.55 -apple-system,BlinkMacSystemFont,sans-serif; max-height:190px; }
  #composer .bar { display:flex; align-items:center; gap:2px; padding:0 8px 8px; }
  #composer .bar .tb { width:30px; height:30px; display:grid; place-items:center;
    border:none; background:none; border-radius:8px; color:var(--ink-faint); cursor:pointer;
    transition:background .15s ease, color .15s ease; }
  #composer .bar .tb:hover { color:var(--ink); background:var(--fill); }
  #composer .bar .hint { margin-left:auto; font:10px ui-monospace,monospace;
    color:var(--ink-fainter); margin-right:6px; }
  #composer .bar .sendbt { width:34px; height:30px; border:none; border-radius:8px;
    display:grid; place-items:center; cursor:pointer; background:var(--line); color:var(--ink-faint);
    transition:background .18s ease, color .18s ease; }
  #composer .bar .sendbt.ready { background:var(--ink); color:var(--paper); }
  #composer svg.lucide { width:15px; height:15px; }
  #picker { position:absolute; bottom:100%; left:12px; right:12px; margin-bottom:8px;
    background:var(--surface); border:1px solid var(--line); border-radius:14px; overflow:hidden;
    box-shadow:0 16px 40px rgba(25,35,55,.18); z-index:20; display:none; }
  #picker.on { display:block; animation:lnin .18s ease; }
  #picker .ph { display:flex; gap:6px; align-items:center; padding:6px 12px;
    font:9.5px ui-monospace,monospace; letter-spacing:.08em; text-transform:uppercase;
    color:var(--ink-faint); border-bottom:1px solid var(--line); }
  #picker .ph svg.lucide { width:11px; height:11px; }
  #picker .rows { max-height:240px; overflow:auto; padding:4px 0; }
  #picker .prow { display:flex; align-items:center; gap:10px; width:100%; text-align:left;
    padding:7px 12px; border:none; background:none; cursor:pointer; font-size:13px; color:var(--ink-2);
    font-family:-apple-system,BlinkMacSystemFont,sans-serif; }
  #picker .prow.act { background:var(--fill); }
  #picker .prow .pic { width:24px; height:24px; border-radius:7px; display:grid;
    place-items:center; flex:none; }
  #picker .prow .pic svg.lucide { width:13px; height:13px; }
  #picker .prow .sig { color:var(--ink-faint); }
  #picker .prow .phint { color:var(--ink-faint); font:11px ui-monospace,monospace; flex:1;
    text-align:right; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  #picker .prow .tag { font:9px ui-monospace,monospace; text-transform:uppercase;
    padding:2px 6px; border-radius:5px; flex:none; }
  #emojipop { position:absolute; bottom:100%; left:12px; margin-bottom:8px; display:none;
    grid-template-columns:repeat(8,1fr); gap:2px; background:var(--surface);
    border:1px solid var(--line); border-radius:12px; padding:6px; width:236px;
    box-shadow:0 12px 32px var(--border-mid); z-index:21; }
  #emojipop.on { display:grid; animation:lnin .18s ease; }
  #emojipop button { font-size:16px; height:28px; border:none; background:none;
    border-radius:6px; cursor:pointer; transition:transform .12s ease; }
  #emojipop button:hover { background:var(--fill); transform:scale(1.12); }

end

## voice a meet style call bar floating

design :voice_a_meet_style_call_bar_floating do
  /* ── voice: a Meet-style call bar floating over the canvas ─────────────── */
  #callbar { position:absolute; bottom:18px; left:50%; transform:translateX(-50%) translateY(16px);
    z-index:9; display:flex; align-items:center; gap:10px; padding:8px 14px;
    background:#1d2126; border-radius:999px; box-shadow:0 14px 40px rgba(0,0,0,.35);
    opacity:0; pointer-events:none;
    transition:opacity .25s ease, transform .28s cubic-bezier(.22,.9,.24,1); }
  #callbar.on { opacity:1; transform:translateX(-50%) translateY(0); pointer-events:auto; }
  #callbar .ind { display:flex; align-items:center; gap:7px; color:var(--green); font:10px ui-monospace,monospace;
    padding-right:4px; }
  #callbar .ind .dotp { width:7px; height:7px; border-radius:50%; background:var(--green);
    animation:pulse 1.6s ease infinite; }
  @keyframes pulse { 0%,100% { box-shadow:0 0 0 0 rgba(106,168,79,.5); } 50% { box-shadow:0 0 0 5px rgba(106,168,79,0); } }
  #callbar button { border:none; border-radius:50%; width:36px; height:36px; cursor:pointer;
    display:flex; align-items:center; justify-content:center; color:var(--line); background:var(--ink-2);
    transition:background .15s ease, transform .12s ease; }
  #callbar button:hover { background:var(--ink-2); }
  #callbar button:active { transform:scale(.94); }
  #callbar button.off { background:var(--ink-2); color:var(--ink-dim); }
  #callbar button.end { background:var(--red); }
  #callbar button.end:hover { background:var(--red); }
  #callbar svg.lucide { width:15px; height:15px; }
  #callbar input { background:var(--ink-2); border:none; border-radius:999px; color:var(--line);
    font:12px -apple-system,BlinkMacSystemFont,sans-serif; padding:8px 14px; width:220px;
    outline:none; }
  #callbar input::placeholder { color:var(--ink-dim); }
  #callbar input:focus { background:var(--ink-2); }
  /* what the autopoet is SAYING, captioned above the call bar while it speaks */
  #callcaption { position:absolute; bottom:76px; left:50%; transform:translateX(-50%) translateY(6px);
    max-width:56%; background:var(--surface); border:1px solid var(--line); border-radius:13px;
    padding:9px 15px; font:12.5px/1.5 -apple-system,BlinkMacSystemFont,sans-serif;
    color:var(--ink-2); box-shadow:0 10px 30px rgba(25,35,55,.14); z-index:9;
    opacity:0; pointer-events:none; transition:opacity .2s ease, transform .22s ease; }
  #callcaption.on { opacity:1; transform:translateX(-50%) translateY(0); }

  /* ── the self node's BODY: the cube avatar (extruded squircle, toon outline).
     One HTML element riding the D3 node through tick+zoom (syncSelfCube);
     during a voice call VoiceStage adopts this same element and lets it
     float free on the whiteboard. ── */
  #self-cube { position:absolute; left:0; top:0; width:132px; height:132px; z-index:5;
    pointer-events:none;
    filter:drop-shadow(0 16px 26px var(--face-drop)); }
  /* the BODY renders in WebGL (avatar3d.mjs — real mesh, inverted-hull toon
     outline). .sc-cube is now just the rotation-variable carrier the drivers
     write to; the face stays a DOM SVG overlay glued on by the render loop. */
  #self-cube .sc-cube { position:absolute; inset:0; pointer-events:auto; cursor:pointer; }
  #self-cube .sc-face { position:absolute; inset:0; display:grid; place-items:center; pointer-events:none; }
  #self-cube .sc-face svg { display:block; width:100%; height:100%; }
  /* reusable cube host (onboarding/login reuses the SAME 3D avatar, scaled) */
  .cube-host .sc-cube { position:absolute; inset:0; pointer-events:auto; cursor:pointer; }
  .cube-host .sc-face { position:absolute; inset:0; display:grid; place-items:center; pointer-events:none; }
  .cube-host .sc-face svg { display:block; width:100%; height:100%; }
  /* the face's eyes+mouth line-art = the character's features (theme-independent) */
  .sc-face svg path { fill: var(--face-features); }
end

## customize autopoet editor cube cente

design :customize_autopoet_editor_cube_cente do
  /* ── customize-autopoet editor: cube centers + scales, graph fades away ── */
  #self-cube.char-edit { left:50%; top:50%; margin:-66px 0 0 -66px;
    transform:scale(1.75) !important; transition:transform .4s cubic-bezier(.2,.8,.2,1); z-index:70; }
  #char-tools { position:fixed; left:50%; bottom:40px; transform:translateX(-50%); z-index:72;
    display:flex; flex-direction:column; align-items:center; gap:12px;
    background:var(--surface); border:1px solid var(--border); border-radius:16px;
    padding:15px 18px 16px; box-shadow:var(--shadow-2);
    font-family:ui-monospace,SFMono-Regular,monospace;
    animation:ctpop .3s cubic-bezier(.2,.8,.2,1); }
  @keyframes ctpop { from { opacity:0; transform:translateX(-50%) translateY(12px); }
    to { opacity:1; transform:translateX(-50%) translateY(0); } }
  #char-tools .ct-title { font-size:10px; letter-spacing:.09em; text-transform:uppercase; color:var(--ink-faint); }
  #char-tools .ct-row { display:flex; gap:8px; align-items:center; justify-content:center; flex-wrap:wrap; }
  .ct-shape { display:inline-flex; align-items:center; gap:7px; font:11px ui-monospace,monospace;
    color:var(--ink-dim); background:var(--fill); border:1px solid var(--border);
    border-radius:9px; padding:6px 11px; cursor:pointer; transition:background .15s, border-color .15s, color .15s; }
  .ct-shape:hover { color:var(--ink); border-color:var(--border-mid); }
  .ct-shape.sel { color:var(--ink); border-color:var(--ink-faint); background:var(--fill-hover); }
  .ct-shape-ic { width:13px; height:13px; background:var(--ink-dim); display:inline-block; }
  .ct-shape.sel .ct-shape-ic { background:var(--ink); }
  .ct-shape-ic.ct-squircle { border-radius:5px; }
  .ct-shape-ic.ct-round { border-radius:50%; }
  .ct-shape-ic.ct-blocky { border-radius:2px; }
  .ct-swatch { width:26px; height:26px; border-radius:8px; cursor:pointer; padding:0;
    background:var(--sw); border:2px solid var(--border); transition:transform .12s; }
  .ct-swatch:hover { transform:translateY(-2px); }
  .ct-swatch.sel { border-color:var(--ink); box-shadow:0 0 0 2px var(--surface), 0 0 0 4px var(--ink-faint); }
  .ct-done { font:600 12px ui-monospace,monospace; color:var(--on-accent); background:var(--btn-solid);
    border:none; border-radius:9px; padding:8px 24px; cursor:pointer; margin-top:2px; }
  .ct-done:hover { background:var(--btn-solid-hover); }
  /* freed for a call: centered anchor + stage-movement vars (VoiceStage drives) */
  #self-cube.vs-free { left:50%; top:50%; margin:-66px 0 0 -66px;
    transform:translate(var(--sx,0px), var(--sy,0px)) scale(var(--sc,1));
    transition:transform .8s cubic-bezier(.3,1,.35,1); }

  /* ── app-wide context menu ───────────────────────────────────────────── */
  #ctx { position:fixed; z-index:30; min-width:180px; background:var(--surface);
    border:1px solid var(--line); border-radius:10px; padding:5px;
    box-shadow:0 12px 36px rgba(25,35,55,.18); display:none;
    opacity:0; transform:scale(.97); transform-origin:top left;
    transition:opacity .14s ease, transform .14s cubic-bezier(.22,.9,.24,1); }
  #ctx.on { display:block; opacity:1; transform:scale(1); }
  #ctx .it { display:flex; align-items:center; gap:9px; padding:6px 10px;
    border-radius:7px; cursor:pointer; font-size:12px; color:var(--ink-2); }
  #ctx .it:hover { background:var(--fill); }
  #ctx .it.danger { color:var(--red); }
  #ctx .it.danger:hover { background:var(--err-bg); }
  #ctx .it svg.lucide { width:13px; height:13px; }
  #ctx .sep { height:1px; background:var(--line); margin:4px 8px; }


  /* onboarding designer additions: voice + personality pickers, meet button */
  #char-tools .ct-pickrow { justify-content:space-between; gap:10px; width:100%; }
  #char-tools .ct-lbl { font:600 10px ui-monospace,monospace; letter-spacing:.08em; text-transform:uppercase;
    color:var(--ink-faint); width:78px; flex:none; text-align:left; }
  #char-tools .ct-pick { display:flex; align-items:center; gap:4px; flex:1; justify-content:space-between;
    border:1px solid var(--border); border-radius:10px; padding:3px 6px; }
  #char-tools .ct-arw { border:0; background:none; cursor:pointer; font:400 18px/1 ui-monospace,monospace;
    color:var(--ink-2); width:24px; height:24px; border-radius:6px; }
  #char-tools .ct-arw:hover { background:var(--surface-2); }
  #char-tools .ct-pname { font:700 13px ui-sans-serif,system-ui; color:var(--ink-strong); flex:1; text-align:center; }
  #char-tools .ct-play { border:0; background:none; cursor:pointer; color:var(--ink-2); width:26px; height:26px;
    border-radius:6px; display:grid; place-items:center; }
  #char-tools .ct-play:hover { background:var(--surface-2); color:var(--ink-strong); }
  #char-tools .ct-play svg { width:15px; height:15px; }
  #char-tools .ct-meet { margin-top:4px; }
end

## canvas badges top right search notif

design :canvas_badges_top_right_search_notif do
  /* ── canvas badges (top-right): search + notifications ───────────────── */
  #canvasbar { position:absolute; top:12px; right:14px; z-index:7;
    display:flex; gap:8px; }
  #canvasbar .cb { position:relative; display:flex; align-items:center; justify-content:center;
    width:32px; height:32px; border-radius:9px; background:var(--surface); cursor:pointer;
    border:1px solid var(--line); color:var(--ink-muted);
    transition:background .15s ease, color .15s ease, transform .12s ease; }
  #canvasbar .cb:hover { background:var(--fill); color:var(--ink); }
  #canvasbar .cb.active { background:var(--fill-hover); color:var(--blue); }
  #canvasbar .cb:active { transform:scale(.95); }
  #canvasbar .cb svg.lucide { width:15px; height:15px; }
  #canvasbar .cb .bdg { position:absolute; top:-5px; right:-5px; min-width:15px; height:15px;
    border-radius:99px; background:var(--amber); color:var(--ink); font-size:9px; font-weight:700;
    display:flex; align-items:center; justify-content:center; padding:0 3px; }
  /* "N hidden" pill — hiding is never invisible-invisible (genesis I3) */
  #flt-pill { position:absolute; top:-7px; right:-10px; background:var(--ink-faint); color:var(--on-accent);
    font-size:9px; line-height:1; padding:2px 6px; border-radius:8px;
    pointer-events:none; white-space:nowrap; }
  #canvasbar .cb .tip { position:absolute; top:38px; right:0; background:var(--ink); color:var(--paper);
    font-size:10px; padding:3px 9px; border-radius:6px; white-space:nowrap;
    opacity:0; pointer-events:none; transform:translateY(-3px);
    transition:opacity .15s ease .15s, transform .15s ease .15s; }
  #canvasbar .cb:hover .tip { opacity:1; transform:none; }
  #canvasbar.active .cb .tip { display:none; }   /* no tooltips under open widgets */

  /* the search badge MORPHS leftward into a bar (panache, not popup).
     Collapsed = a perfect 32px square, input fully hidden. */
  #cb-search { width:32px; overflow:hidden;
    transition:width .32s cubic-bezier(.22,.9,.24,1), background .15s ease, border-color .2s ease; }
  #cb-search input { display:none; flex:1; min-width:0; border:none; outline:none;
    background:none; font:12px ui-monospace,monospace; color:var(--ink); padding:0; }
  #cb-search.expanded { width:264px; cursor:default; border-color:var(--blue-soft);
    justify-content:flex-start; padding:0 10px; gap:8px; }
  #cb-search.expanded input { display:block; animation:fadein .18s ease .12s both; }
  #cb-search.expanded > svg.lucide { color:var(--blue-soft); }
  @keyframes fadein { from { opacity:0; } }

  #searchpop { position:absolute; top:52px; right:54px; z-index:8; width:264px;
    background:var(--surface); border:1px solid var(--line); border-radius:11px; padding:6px;
    box-shadow:0 12px 36px var(--border-mid); display:none;
    opacity:0; transform:translateY(-6px);
    transition:opacity .18s ease, transform .18s cubic-bezier(.22,.9,.24,1); }
  #searchpop.on { display:block; opacity:1; transform:none; }
  #searchpop .res { max-height:260px; overflow:auto; margin-top:6px; }
  #searchpop .res .it { display:flex; align-items:center; gap:8px; padding:5px 9px;
    border-radius:7px; cursor:pointer; font-size:12px; }
  #searchpop .res .it:hover { background:var(--fill); }
  #searchpop .res .sw { width:9px; height:9px; border-radius:50%; flex:none; }

  #notif { position:absolute; top:52px; right:14px; bottom:14px; z-index:8; width:320px;
    background:var(--surface); border:1px solid var(--line); border-radius:12px;
    box-shadow:0 14px 40px var(--border-mid); display:none; flex-direction:column;
    opacity:0; transform:translateX(10px);
    transition:opacity .2s ease, transform .22s cubic-bezier(.22,.9,.24,1); }
  #notif.on { display:flex; opacity:1; transform:none; }
  #notif .nh { padding:11px 14px; font-size:11px; font-weight:600; letter-spacing:.05em;
    color:var(--ink-faint); border-bottom:1px solid var(--line); }
  #notif .body { flex:1; overflow:auto; padding:8px; }
  #notif .card { border:1px solid var(--line); border-radius:10px; padding:10px 12px;
    margin-bottom:8px; }
  #notif .card .t { font-size:12px; font-weight:600; margin-bottom:3px; }
  #notif .card .d { font-size:11px; color:var(--ink-dim);
    font-family:-apple-system,BlinkMacSystemFont,sans-serif; margin-bottom:8px; }
  #notif .card button { font:10px ui-monospace,monospace; border:1px solid var(--line);
    background:var(--surface); border-radius:6px; padding:3px 10px; cursor:pointer; margin-right:6px; }
  #notif .card button.ok { background:var(--ok-bg); }
  #notif .card button.no { background:var(--err-bg); }
  #notif .ev { font-size:10px; color:var(--ink-faint); padding:3px 6px; }

  /* tree drag-drop */
  #tree li > .row.dragover { background:var(--sel-bg); outline:1px dashed var(--blue-soft); }

  /* custom chrome (frameless mode). z-index:1000 — ABOVE every overlay in the app
     (onboard:60, backdrop:20, modal:21, footpop/filterpop:40, toast:80, error
     banner:99) so the stoplight stays visible and clickable no matter what's up. */
  #chrome { position:fixed; top:0; left:0; width:240px; height:32px; z-index:1000;
    display:var(--chrome-display); align-items:center; gap:8px; padding-left:13px;
    -webkit-app-region:drag; }
  .tl { width:12px; height:12px; border-radius:50%; cursor:pointer; -webkit-app-region:no-drag; }
  .tl.close { background:#ff5f57; } .tl.min { background:#febc2e; } .tl.max { background:#28c840; }
  /* persistent top drag strip — present in EVERY state (onboarding included),
     always above every overlay, so the window is always draggable by its top
     edge. Deliberately slim (7px, under the 7px/12px offsets where #toprow and
     #canvasbar's own controls start) so it needs no layout reservation anywhere
     — it just rides in the dead space that already existed above them. */
  #dragbar { position:fixed; top:0; left:0; right:0; height:7px; z-index:1000;
    display:var(--chrome-display); -webkit-app-region:drag; }

end

## sidebar footer account settings env

design :sidebar_footer_account_settings_env do
  /* ── sidebar footer: account · settings · env ── */
  #sidebarfoot { flex:none; display:flex; align-items:center; gap:6px; padding:8px 12px 10px;
    border-top:1px solid var(--line); }
  #sidebarfoot .footgap { flex:1; }
  .footprofile { width:28px; height:28px; border-radius:50%; border:none; cursor:pointer;
    background:var(--purple); color:var(--on-accent); font:600 12px ui-monospace,monospace;
    display:flex; align-items:center; justify-content:center; transition:filter .15s ease; }
  .footprofile:hover { filter:brightness(1.08); }
  .footbtn { width:28px; height:28px; border:none; background:none; border-radius:8px;
    color:var(--ink-dim); cursor:pointer; display:flex; align-items:center; justify-content:center;
    transition:background .15s ease, color .15s ease; }
  .footbtn:hover { background:var(--line); color:var(--ink-2); }
  .footbtn svg.lucide { width:16px; height:16px; }
  .footbtn .envE { font:700 14px ui-monospace,monospace; }
  /* the footer popups (open upward from the footer) */
  #footpop { position:fixed; z-index:40; display:none; background:var(--surface); border:1px solid var(--line);
    border-radius:12px; box-shadow:0 14px 40px rgba(25,35,55,.18); padding:6px; min-width:210px; }
  #footpop.on { display:block; }
  #footpop .fp-head { display:flex; align-items:center; gap:10px; padding:8px 9px 10px; }
  #footpop .fp-av { width:34px; height:34px; border-radius:50%; background:var(--purple); color:var(--on-accent);
    font:600 14px ui-monospace,monospace; display:flex; align-items:center; justify-content:center; flex:none; }
  #footpop .fp-name { font-weight:600; font-size:13px; color:var(--ink-2); }
  #footpop .fp-mail { font:11px ui-monospace,monospace; color:var(--ink-faint); }
  #footpop .fp-sep { height:1px; background:var(--border); margin:4px 2px; }
  #footpop .fp-title { font-size:11px; letter-spacing:.05em; color:var(--ink-faint); padding:6px 9px 4px; text-transform:uppercase; }
  #footpop .fp-item { display:flex; align-items:center; gap:9px; width:100%; text-align:left;
    font:inherit; font-size:12.5px; color:var(--ink-2); border:none; background:none; cursor:pointer;
    padding:8px 9px; border-radius:8px; }
  #footpop .fp-item:hover { background:var(--fill); }
  #footpop .fp-item.danger:hover { background:var(--err-bg); color:var(--red); }
  #footpop .fp-item svg.lucide { width:15px; height:15px; color:var(--ink-faint); }
  #footpop .fp-item.danger:hover svg.lucide { color:var(--red); }
  /* settings: theme segmented toggle */
  #footpop .fp-seg { display:flex; gap:4px; padding:4px 9px 8px; }
  #footpop .fp-seg button { flex:1; display:flex; align-items:center; justify-content:center; gap:6px;
    font:inherit; font-size:12px; color:var(--ink-dim); border:1px solid var(--line); background:var(--surface);
    border-radius:8px; padding:7px; cursor:pointer; }
  #footpop .fp-seg button.sel { border-color:var(--blue-soft); background:var(--fill-hover); color:var(--ink-2); font-weight:600; }
  #footpop .fp-seg svg.lucide { width:13px; height:13px; }
  /* workbooks cloud panel */
  .cpanel-back { position:fixed; inset:0; z-index:60; background:rgba(20,28,42,.32);
    display:grid; place-items:center; padding:20px; }
  .cpanel { width:400px; max-width:100%; background:var(--surface); border:1px solid var(--line);
    border-radius:14px; box-shadow:0 24px 60px -18px rgba(20,28,42,.4); overflow:hidden; }
  .cpanel-h { display:flex; align-items:center; justify-content:space-between; padding:15px 18px;
    border-bottom:1px solid var(--border); font:600 14.5px system-ui; color:var(--ink-2); }
  .cpanel-x { border:none; background:none; font-size:21px; line-height:1; color:var(--ink-faint); cursor:pointer; padding:0 4px; }
  .cpanel-x:hover { color:var(--ink-2); }
  .cpanel-b { padding:18px; }
  .cpanel-load, .cp-lede { font:13px/1.5 system-ui; color:var(--ink-dim); margin:0 0 14px; }
  .cp-row { display:flex; align-items:center; justify-content:space-between; padding:9px 0; border-bottom:1px solid var(--fill); }
  .cp-row:last-of-type { border-bottom:none; }
  .cp-k { font:11px ui-monospace,monospace; letter-spacing:.04em; text-transform:uppercase; color:var(--ink-faint); }
  .cp-v { font:12.5px ui-monospace,monospace; color:var(--ink-2); display:flex; align-items:center; gap:7px; }
  .cp-dot { width:8px; height:8px; border-radius:50%; background:var(--ink-faint); flex:none; }
  .cp-dot.on { background:var(--green); } .cp-dot.warn { background:var(--amber); } .cp-dot.off { background:var(--border); }
  .cp-actions { display:flex; gap:9px; margin-top:16px; }
  .cp-btn { flex:1; font:600 12.5px system-ui; padding:10px; border-radius:9px; border:1px solid var(--btn-solid);
    background:var(--btn-solid); color:var(--on-accent); cursor:pointer; }
  .cp-btn:hover { background:var(--btn-solid-hover); }
  .cp-btn:disabled { opacity:.6; cursor:default; }
  .cp-btn.ghost { background:var(--surface); color:var(--ink-2); border-color:var(--line); }
  .cp-btn.ghost:hover { background:var(--fill); }
  .cp-btn.ghost.danger:hover { background:var(--err-bg); color:var(--red); border-color:var(--err-bg); }
  .cp-note { font:11.5px/1.5 ui-monospace,monospace; color:var(--ink-faint); margin:12px 0 0; }
  /* env: key/value editor */
  #footpop .fp-env { display:flex; flex-direction:column; gap:5px; padding:4px 8px 8px; max-height:240px; overflow:auto; }
  #footpop .fp-envrow { display:flex; gap:5px; align-items:center; }
  #footpop .fp-envrow input { font:11.5px ui-monospace,monospace; border:1px solid var(--line);
    border-radius:7px; padding:5px 7px; outline:none; min-width:0; }
  #footpop .fp-envrow .k { width:44%; } #footpop .fp-envrow .v { flex:1; }
  #footpop .fp-envrow .rm { border:none; background:none; color:var(--ink-fainter); cursor:pointer; font-size:15px; padding:0 3px; }
  #footpop .fp-envrow .rm:hover { color:var(--red); }
  #footpop .fp-envadd { font:inherit; font-size:11.5px; color:var(--ink-dim); border:1px dashed var(--line);
    background:none; border-radius:8px; padding:6px; cursor:pointer; margin:2px 8px 4px; }
  #footpop .fp-envadd:hover { border-color:var(--border); color:var(--ink); }
  #footpop .fp-note { font:10.5px ui-monospace,monospace; color:var(--ink-fainter); padding:2px 10px 6px; }

  /* filter · views popup (top-right, under the filter icon) */
  #filterpop { position:fixed; z-index:40; display:none; background:var(--surface); border:1px solid var(--line);
    border-radius:12px; box-shadow:0 14px 40px var(--border-mid); padding:6px; min-width:206px; }
  #filterpop.on { display:block; }
  #filterpop .flt-title { font-size:11px; letter-spacing:.05em; text-transform:uppercase; color:var(--ink-faint); padding:6px 9px 4px; }
  #filterpop .flt-row { display:flex; align-items:center; gap:9px; padding:6px 9px; border-radius:8px; cursor:pointer; }
  #filterpop .flt-row:hover { background:var(--fill); }
  #filterpop .flt-row input { accent-color:var(--blue-soft); cursor:pointer; }
  #filterpop .flt-sw { width:10px; height:10px; border-radius:3px; flex:none; }
  #filterpop .flt-l { flex:1; font-size:12.5px; color:var(--ink-2); text-transform:capitalize; }
  #filterpop .flt-n { font:10px ui-monospace,monospace; color:var(--ink-fainter); }
  #filterpop .flt-sep { height:1px; background:var(--border); margin:5px 2px; }
  #filterpop .flt-all { font:inherit; font-size:12px; color:var(--ink-dim); border:none; background:none; cursor:pointer; padding:6px 9px; border-radius:8px; width:100%; text-align:left; }
  #filterpop .flt-all:hover { background:var(--fill); color:var(--ink); }
  #filterpop .flt-note { font:10.5px ui-monospace,monospace; color:var(--border); padding:4px 9px 3px; }
  #filterpop .flt-ic { border:none; background:none; color:var(--ink-fainter); cursor:pointer; padding:2px;
    border-radius:5px; display:flex; align-items:center; }
  #filterpop .flt-ic:hover { background:var(--line); color:var(--ink-2); }
  #filterpop .flt-ic svg.lucide { width:12px; height:12px; }
  #filterpop .flt-cl .flt-l { cursor:pointer; }
  /* the tool row: icon squircles — click to arm a tool / open its composer */
  #filterpop .flt-tools { display:flex; gap:6px; padding:2px 9px 7px; }
  #filterpop .flt-tool { width:32px; height:32px; display:flex; align-items:center; justify-content:center;
    border:1px solid var(--line); background:var(--surface); color:var(--ink-dim); border-radius:9px; cursor:pointer;
    transition:background .15s ease, color .15s ease, border-color .15s ease; }
  #filterpop .flt-tool:hover { background:var(--fill-hover); color:var(--ink); border-color:var(--border); }
  #filterpop .flt-tool.sel { border-color:var(--blue-soft); background:var(--fill-hover); color:var(--blue); }
  #filterpop .flt-tool svg.lucide { width:15px; height:15px; }
  /* the ask composer: a proper multi-line prompt box */
  #filterpop .flt-composer { padding:2px 9px 7px; }
  #filterpop .flt-composer textarea { width:100%; box-sizing:border-box;
    resize:vertical; min-height:58px; max-height:260px;
    font:11.5px ui-monospace,monospace; line-height:1.5; color:var(--ink-2);
    border:1px solid var(--line); border-radius:9px; padding:8px 10px; outline:none; }
  #filterpop .flt-composer textarea:focus { border-color:var(--blue-soft); }
  #filterpop .flt-compbar { display:flex; align-items:center; justify-content:flex-end; gap:8px; margin-top:5px; }
  #filterpop .flt-compbar .hint { font:10px ui-monospace,monospace; color:var(--border); }
  #filterpop .flt-compbar button { display:flex; align-items:center; gap:6px; font:inherit; font-size:11.5px;
    background:var(--blue); border:1px solid var(--blue); color:var(--on-accent); border-radius:8px; padding:5px 12px; cursor:pointer; }
  #filterpop .flt-compbar button:hover { background:var(--blue-deep); }
  #filterpop .flt-compbar svg.lucide { width:12px; height:12px; }
  /* collapsible filter section header */
  #filterpop .flt-collhead { display:flex; align-items:center; gap:6px; width:100%; text-align:left;
    font:inherit; font-size:11px; letter-spacing:.05em; text-transform:uppercase; color:var(--ink-faint);
    border:none; background:none; cursor:pointer; padding:6px 9px 4px; border-radius:8px; }
  #filterpop .flt-collhead:hover { color:var(--ink-2); }
  #filterpop .flt-collhead svg.lucide { width:12px; height:12px; }
  /* on-canvas cluster dressing */
  .cl-lbl { font:600 12px ui-monospace,monospace; letter-spacing:.04em; pointer-events:all; }
  .cl-count { font:700 13px ui-monospace,monospace; fill:var(--on-accent); pointer-events:none; }
  .cl-badge-t { font:600 12px ui-monospace,monospace; letter-spacing:.02em; }
  .cl-pin { fill:var(--on-accent); stroke-width:2; cursor:grab; }
  .cl-pin:hover { r:6; }
  .cl-pin-preview { opacity:.5; stroke-dasharray:2.5 2.5; }
  .lasso { fill:rgba(91,140,201,.07); stroke:var(--blue-soft); stroke-width:1.5;
    stroke-dasharray:6 5; pointer-events:none; }
  /* lassoed nodes: a dotted highlight ring */
  g.selnode > circle, g.selnode > rect { stroke:var(--blue); stroke-dasharray:5 4; stroke-width:2.5; }
  /* floating selection toolbar (appears while something is selected) */
  #seltool { position:fixed; z-index:30; transform:translateX(-50%); display:none;
    align-items:center; gap:9px; background:var(--surface); border:1px solid var(--line); border-radius:999px;
    padding:7px 8px 7px 14px; box-shadow:0 10px 30px var(--border-mid); }
  #seltool.on { display:flex; }
  #seltool .selcount { font:600 11.5px ui-monospace,monospace; color:var(--ink-muted); }
  #seltool button { display:flex; align-items:center; gap:6px; font:inherit; font-size:12px;
    border:1px solid var(--line); background:var(--surface); color:var(--ink-dim); border-radius:999px;
    padding:5px 12px; cursor:pointer; }
  #seltool button:hover { background:var(--fill-hover); color:var(--ink); }
  #seltool #sel-group { background:var(--blue); border-color:var(--blue); color:var(--on-accent); }
  #seltool #sel-group:hover { background:var(--blue-deep); }
  #seltool svg.lucide { width:13px; height:13px; }
  /* colour palette (new-cluster modal + cluster panel) */
  .clpal { display:flex; gap:7px; margin:11px 2px; }
  .clpal .swb { width:20px; height:20px; border-radius:50%; border:2px solid transparent;
    cursor:pointer; padding:0; box-shadow:0 0 0 1.5px var(--surface) inset; }
  .clpal .swb.sel { border-color:var(--ink-strong); }
  /* cluster panel fields */
  #panel .clrow { margin:7px 0; }
  #panel .clrow input, #panel .clrow textarea { width:100%; box-sizing:border-box; font:12px ui-monospace,monospace;
    border:1px solid var(--line); border-radius:8px; padding:6px 9px; outline:none; resize:vertical;
    background:var(--surface-2); color:var(--ink); }
  #panel .clrow input::placeholder, #panel .clrow textarea::placeholder { color:var(--ink-dim); }
  #panel .clrow input:focus, #panel .clrow textarea:focus { border-color:var(--blue-soft); }
  #panel .clacts { display:flex; gap:6px; margin-top:4px; }
  #panel .clacts button { font:inherit; font-size:11.5px; padding:5px 12px; border-radius:8px;
    border:1px solid var(--line); background:var(--surface); color:var(--ink-dim); cursor:pointer; }
  #panel .clacts button:hover { color:var(--ink); background:var(--fill); }
  #panel .clacts .no:hover { background:var(--err-bg); color:var(--red); }

end

## onboarding sign in a pre app screen 

design :onboarding_sign_in_a_pre_app_screen do
  /* ── onboarding / sign-in (a pre-app screen; plain white, centered) ── */
  #onboard { position:fixed; inset:0; z-index:60; background:var(--surface); display:flex;
    align-items:center; justify-content:center; -webkit-app-region:drag; }
  #onboard.hidden { display:none; }
  #onboard button, #onboard .signbtn { -webkit-app-region:no-drag; }
  .obinner { display:flex; flex-direction:column; gap:34px; max-width:560px; padding:40px; }
  .obrow { display:flex; align-items:stretch; gap:28px; }
  /* the face rides SMALL, above the wordmark (the big side-by-side avatar ghosted
     in the desktop WebKit shell; this compact layout renders clean) */
  .obdef { text-align:left; align-self:center; }
  /* one voice: the app's monospace — the serif experiment is retired */
  #onboard { font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
  .obword { font:600 32px ui-monospace,SFMono-Regular,Menlo,monospace;
    color:var(--ink-strong); letter-spacing:-.02em; line-height:1; }
  .obph { font:12px ui-monospace,monospace; color:var(--ink-faint); margin-top:7px; }
  .obph .obpo { color:var(--purple); }
  .obtext { font:13px/1.65 ui-monospace,SFMono-Regular,Menlo,monospace;
    color:var(--ink-2); margin:14px 0 0; }
  .obcode { font:12px ui-monospace,monospace; color:var(--ink-fainter); margin-top:13px; }
  /* OAuth entry — GitHub / Google (stubbed providers behind Autopoet.Auth).
     Buttons hug the LEFT edge, aligned with the definition text above. */
  .obsignrow { justify-content:flex-start; }
  .oblogins { display:flex; flex-direction:column; gap:10px; align-items:flex-start; }
  .oauthbtn { display:flex; align-items:center; justify-content:center; gap:10px; width:280px;
    font:600 12.5px ui-monospace,SFMono-Regular,Menlo,monospace; color:var(--ink-strong);
    padding:10px 20px; border-radius:12px; border:1px solid var(--border); background:var(--surface);
    cursor:pointer; -webkit-app-region:no-drag;
    transition:border-color .16s ease, box-shadow .16s ease; }
  .oauthbtn:hover { border-color:var(--border); box-shadow:0 1px 4px rgba(25,35,55,.1); }
  .oauthbtn svg { flex:none; }
  /* the MAIN door — Sign in with Workbooks (primary, dark) */
  .oauthbtn-primary { background:var(--btn-solid); color:var(--on-accent); border-color:var(--btn-solid); }
  .oauthbtn-primary:hover { background:var(--btn-solid-hover); border-color:var(--btn-solid-hover); box-shadow:0 2px 8px rgba(0,0,0,.18); }
  .oauthbtn-primary.waiting { opacity:.6; cursor:progress; }
  .obsignhint { margin-top:10px; font:11px ui-monospace,monospace; color:var(--ink-dim); text-align:center; }
  /* POWER GATE — cloud vs local AI, the required onboarding choice */
  .powergrid { display:grid; grid-template-columns:1fr 1fr; gap:14px; width:100%; margin:4px 0 2px; }
  .powercard { display:flex; flex-direction:column; gap:8px; padding:18px; border:1px solid #e2e6ec;
    border-radius:14px; background:#fff; position:relative; min-height:190px; }
  .powercard.reco { border-color:#16161a; box-shadow:0 2px 10px rgba(0,0,0,.06); }
  .pc-badge { position:absolute; top:-9px; left:16px; background:#16161a; color:#fff; font:600 9.5px ui-monospace,monospace;
    letter-spacing:.04em; text-transform:uppercase; padding:3px 8px; border-radius:6px; }
  .pc-name { font:600 14px ui-monospace,monospace; color:#1c2230; }
  .pc-price { font:15px ui-monospace,monospace; color:#16161a; }
  .pc-price b { font-size:26px; } .pc-price span { color:#8a8f88; font-size:12.5px; }
  .pc-line { font:12px/1.5 ui-monospace,monospace; color:#6a6f68; flex:1; }
  .obstepgo.alt { background:#eef0f2; color:#1c2230; }
  .obstepgo.alt:hover { background:#e2e6ec; }
  .pc-foot { display:flex; align-items:center; justify-content:space-between; gap:14px; width:100%; margin-top:6px; }
  /* inline cloud billing panel */
  .billpanel { display:flex; flex-direction:column; gap:2px; width:100%; border:1px solid #e2e6ec; border-radius:12px; overflow:hidden; }
  .bp-row { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:13px 16px; border-bottom:1px solid #eef0f2; }
  .bp-row:last-child { border-bottom:0; }
  .bp-row label { font:12.5px ui-monospace,monospace; color:#1c2230; }
  .bp-check { display:flex; align-items:center; gap:8px; cursor:pointer; }
  .bp-inline { font:12.5px ui-monospace,monospace; color:#6a6f68; display:flex; align-items:center; gap:5px; }
  .bp-num { width:64px; padding:5px 7px; text-align:right; }
  #bp-tier { width:auto; min-width:200px; padding:6px 10px; }
  #bp-modal { position:fixed; inset:0; z-index:90; background:rgba(15,16,20,.55); display:grid; place-items:center; }
  .bpm-card { width:min(460px,94vw); height:min(660px,92vh); background:#fff; border-radius:14px; overflow:hidden; display:flex; flex-direction:column; box-shadow:0 20px 60px rgba(0,0,0,.35); }
  .bpm-head { display:flex; align-items:center; justify-content:space-between; padding:11px 14px; border-bottom:1px solid #eef0f2; font:600 12px ui-monospace,monospace; }
  .bpm-head a, .bpm-head button { font:11px ui-monospace,monospace; color:#245cc0; background:none; border:0; cursor:pointer; }
  #bpm-frame { flex:1; border:0; width:100%; }
end

## interactive plan mode the bottom nex

design :interactive_plan_mode_the_bottom_nex do
  /* ── interactive plan mode: the bottom next/back widget over the vs stage ──
     (the stage itself — cube, hands, D2 board, captions — is voice-stage.js) */
  .pm-widget { position:fixed; left:50%; transform:translateX(-50%); bottom:14px; z-index:64;
    width:min(580px,92%); background:#fff; border:1px solid #e2e6ec; border-radius:15px; padding:14px 16px 12px;
    box-shadow:0 10px 34px rgba(20,30,50,.13); display:flex; flex-direction:column; gap:10px; }
  .pm-q { font:13px/1.55 ui-monospace,monospace; color:#1c2230; min-height:38px; }
  .pm-nav { display:flex; align-items:center; justify-content:space-between; }
  .pm-btn { font:600 12px ui-monospace,monospace; padding:8px 16px; border-radius:10px; border:0;
    background:#16161a; color:#fff; cursor:pointer; }
  .pm-btn.ghost { background:#eef0f2; color:#1c2230; }
  .pm-dots { display:flex; gap:5px; }
  .pm-dots i { width:6px; height:6px; border-radius:50%; background:#dfe3e9; }
  .pm-dots i.on { background:#16161a; }
  .pm-tools { display:flex; align-items:center; gap:8px; }
  .pm-ico { display:grid; place-items:center; width:32px; height:32px; border-radius:9px; border:1px solid #e2e6ec;
    background:#fff; cursor:pointer; color:#1c2230; }
  .pm-ico:hover { border-color:#b9c2cd; }
  .pm-ico svg { width:15px; height:15px; }
  /* NO NAVIGATION — the intro auto-runs. Only a tiny utility cluster (sound +
     dev voice lab) floats bottom-left; it is not a nav bar. */
  .pm-tools-float { position:fixed; left:16px; bottom:16px; z-index:64; display:flex; gap:8px;
    align-items:center; }
  .pm-tools-float .pm-ico { box-shadow:0 2px 8px rgba(22,22,26,.08); }
  .pm-enter { font:700 12.5px ui-monospace,monospace; letter-spacing:.06em; padding:10px 18px;
    border-radius:10px; border:0; background:#16161a; color:#fff; cursor:pointer; margin-left:6px;
    animation:pm-enter-in .5s cubic-bezier(.34,1.5,.4,1) both; }
  .pm-enter:hover { background:#2e2e34; }
  @keyframes pm-enter-in { from { opacity:0; transform:translateY(8px) scale(.9); } }
  /* the deck arrows — browse the pitch slides (the only nav the user gets) */
  .pm-deck-nav { position:fixed; right:18px; bottom:16px; z-index:64; display:flex; gap:8px;
    animation:pm-enter-in .5s cubic-bezier(.34,1.5,.4,1) both; }
  .pm-arrow { width:40px; height:40px; border-radius:11px; border:1px solid #e2e6ec; background:#fff;
    color:#1c2230; font:400 22px/1 ui-monospace,monospace; cursor:pointer; display:grid; place-items:center;
    box-shadow:0 2px 8px rgba(22,22,26,.08); }
  .pm-arrow:hover { border-color:#b9c2cd; background:#f6f8fa; }
  /* the caption sits above the widget while plan mode is on */
  body:has(.pm-widget) #vs-caption { bottom:132px; }
  /* PLAN SCREEN — onboarding owns the viewport: no dashboard chrome, just the
     whiteboard stage (sidebar, canvasbar, console, call chrome all yield) */
  body.pm-screen #tree { display:none !important; }
  body.pm-screen #modetoggle { display:none !important; }
  body.pm-screen #stage { position:fixed; inset:0; z-index:55; background:var(--paper,#fff); }
  body.pm-screen #stage > #canvasbar,
  body.pm-screen #stage > #console,
  body.pm-screen #stage > #callcaption,
  body.pm-screen #stage > #callbar { display:none !important; }
  /* onboarding steps (the cold-start flow after sign UP) */
  #obsteps { display:none; flex-direction:column; align-items:flex-start; gap:16px; max-width:500px; padding:40px; text-align:left; }
  .obstepgo { font:12.5px ui-monospace,monospace; padding:9px 18px; border-radius:10px;
    border:1px solid var(--blue); background:var(--blue); color:var(--on-accent); cursor:pointer; -webkit-app-region:no-drag; }
  .obstepgo:hover { background:var(--blue-deep); }
  .obsface { width:72px; height:72px; border-radius:16px; border:1px solid rgba(0,0,0,.12);
    background:var(--surface); overflow:hidden; }
  .obinput { font:13px ui-monospace,SFMono-Regular,Menlo,monospace; color:var(--ink-strong);
    padding:9px 12px; border-radius:10px; border:1px solid var(--border); background:var(--surface);
    outline:none; width:280px; -webkit-app-region:no-drag; }
  .obinput:focus { border-color:var(--purple); box-shadow:0 0 0 3px rgba(142,124,195,.14); }
  .obhow { display:flex; flex-direction:column; gap:10px; margin:2px 0 6px; }
  .obhowrow { display:flex; gap:12px; font:12.5px/1.55 ui-monospace,monospace; color:var(--ink-2); }
  .obhowk { flex:none; width:86px; text-align:right; color:var(--purple); font-weight:600; }
  /* connect cards — square, one per provider; connected = quiet green ring + check */
  /* cards flex-fill the row so the abilities card below lines up EXACTLY */
  .obcards { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin:4px 0 2px; width:100%; }
  .obabil { display:flex; flex-direction:column; gap:7px; width:100%; box-sizing:border-box;
    padding:13px 15px; border:1px solid var(--line); border-radius:14px; background:var(--surface-2); }
  .abrow { display:flex; align-items:center; gap:9px; font:11.5px ui-monospace,monospace; color:var(--ink-faint); }
  .abrow.on { color:var(--ink-2); }
  .abck { flex:none; width:15px; height:15px; color:var(--border); }
  .abrow.on .abck { color:var(--green); }
  .abck svg { width:15px; height:15px; }
  .absrc { margin-left:auto; font-size:10px; color:var(--border); }
  .obcard { position:relative; aspect-ratio:1; min-width:0;
    display:flex; flex-direction:column;
    align-items:flex-start; justify-content:flex-end; gap:6px; padding:14px;
    border:1px solid var(--border); border-radius:14px; background:var(--surface); cursor:pointer;
    -webkit-app-region:no-drag; transition:border-color .16s ease, box-shadow .16s ease; }
  /* every card: a fixed logo slot pinned top-left, logos normalized to one size */
  .oblogo { height:26px; margin-bottom:auto; display:flex; align-items:center; }
  .oblogo svg, .oblogo img { height:22px !important; width:auto !important; max-width:30px; object-fit:contain; display:block; }
  .obcard:hover { border-color:var(--border); box-shadow:0 1px 4px rgba(25,35,55,.1); }
  .obcard.on { border-color:var(--green); box-shadow:0 0 0 3px rgba(106,168,79,.12); }
  .obcard.pending { border-color:var(--purple); box-shadow:0 0 0 3px rgba(142,124,195,.14); }
  .obcard.pending .obcardname::after { content:" …"; color:var(--purple); }
  .obcardname { font:600 13px ui-monospace,monospace; color:var(--ink-strong); }
  .obcardline { font:10.5px/1.45 ui-monospace,monospace; color:var(--ink-dim); }
  .obck { position:absolute; top:10px; right:10px; display:none; color:var(--green); }
  .obck svg { width:16px; height:16px; }
  .obcard.on .obck { display:block; }
  /* behavior lab panel (dev) */
  #blab{position:fixed;right:16px;top:56px;z-index:66;width:250px;background:#fff;border:1.6px solid #e2e6ec;
    border-radius:14px;padding:13px 14px;box-shadow:0 12px 40px rgba(20,30,50,.16);
    font:11px ui-monospace,monospace;color:#1c2230;display:flex;flex-direction:column;gap:8px}
  #blab .bl-hd{display:flex;justify-content:space-between;align-items:center;font-size:12px}
  #blab .bl-hd button{border:0;background:none;cursor:pointer;font-size:13px;color:#8a8f88}
  #blab select{appearance:none;-webkit-appearance:none;font:600 11.5px ui-monospace,monospace;
    padding:6px 10px;border:1.4px solid #d6dbe2;border-radius:9px;background:#fff;cursor:pointer}
  #blab .bl-row{display:flex;gap:6px;flex-wrap:wrap}
  #blab .bl-row button{flex:1;font:600 10.5px ui-monospace,monospace;padding:6px 8px;border-radius:8px;
    border:1px solid #d6dbe2;background:#fff;cursor:pointer;white-space:nowrap}
  #blab .bl-row button:hover{background:#16161a;color:#fff}
  #blab .bl-tr{display:flex;align-items:center;gap:6px;color:#6a6f68}
  #blab .bl-tr span{width:104px;flex:none}
  #blab .bl-tr input{flex:1;accent-color:#16161a;height:12px}
  #blab .bl-note{font:500 10.5px ui-monospace,monospace;color:#8a8f88;min-height:12px}
  #blab .bl-meter{height:5px;background:#eef0f2;border-radius:3px;overflow:hidden}
  #blab .bl-meter i{display:block;height:100%;width:0;background:#16161a}

/* ── THE PLAN CONVERSATION — interjection bar, fork cards, chat, processing ── */
.pm-bar{position:fixed;left:50%;transform:translateX(-50%);bottom:16px;z-index:66;
  display:flex;align-items:center;gap:8px;width:min(560px,86vw);
  background:#fff;border:1.6px solid #e2e6ec;border-radius:14px;padding:7px 8px 7px 14px;
  box-shadow:0 6px 24px rgba(22,22,26,.10);animation:pm-enter-in .5s cubic-bezier(.34,1.5,.4,1) both}
/* the composer is a TEXTAREA so the full transcript shows as it grows (talking
   or typing); it auto-grows in JS up to max-height, then scrolls */
.pm-bar textarea{flex:1;border:0;outline:none;background:transparent;resize:none;overflow-y:auto;
  font:14px/1.45 ui-sans-serif,system-ui;color:#1c2230;max-height:200px;padding:5px 0;min-height:22px}
.pm-send{width:34px;height:34px;flex:none;border:0;border-radius:10px;background:#16161a;color:#fff;
  font-size:16px;cursor:pointer;align-self:flex-end}
.pm-send:hover{background:#2e2e34}
/* fork — the one physical choice: three direction cards */
.pm-fork{position:fixed;inset:0;z-index:70;display:grid;place-items:center;
  background:rgba(250,250,248,.55);backdrop-filter:blur(3px);opacity:0;transition:opacity .3s ease}
.pm-fork.on{opacity:1}
.pm-fork.done{opacity:0;pointer-events:none}
.pm-fork-cards{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;max-width:900px;padding:20px}
.pm-card{width:240px;min-height:150px;text-align:left;background:#fff;border:1.6px solid #16161a;
  border-radius:14px;padding:16px 16px 18px;cursor:pointer;display:flex;flex-direction:column;gap:8px;
  box-shadow:4px 6px 0 rgba(22,22,26,.12);transition:transform .18s ease, box-shadow .18s ease;
  animation:pm-card-in .5s cubic-bezier(.34,1.5,.4,1) both}
.pm-card:nth-child(2){animation-delay:.07s}.pm-card:nth-child(3){animation-delay:.14s}
.pm-card:hover{transform:translateY(-4px);box-shadow:6px 9px 0 rgba(22,22,26,.16)}
.pm-card.picked{background:#16161a;color:#fff;transform:scale(1.03)}
.pm-card-k{font:600 10px ui-monospace,monospace;letter-spacing:.14em;text-transform:uppercase;color:#8a8f88}
.pm-card.picked .pm-card-k{color:#c9cdd2}
.pm-card-t{font:700 17px/1.2 ui-sans-serif,system-ui}
.pm-card-m{font:13px/1.45 ui-sans-serif,system-ui;color:#5a6068}
.pm-card.picked .pm-card-m{color:#e2e6ec}
@keyframes pm-card-in{from{opacity:0;transform:translateY(14px) scale(.96)}}
/* transient chat bubbles (what was just said, both sides) */
.pm-chat{position:fixed;left:50%;transform:translateX(-50%);bottom:74px;z-index:63;
  display:flex;flex-direction:column;gap:6px;align-items:center;width:min(560px,86vw);pointer-events:none}
.pm-bub{max-width:90%;font:13px/1.4 ui-sans-serif,system-ui;padding:6px 12px;border-radius:12px;
  transition:opacity .8s ease;opacity:.96}
.pm-bub.you{align-self:flex-end;background:#16161a;color:#fff}
.pm-bub.ap{align-self:flex-start;background:#eef0f2;color:#1c2230}
.pm-bub.fade{opacity:0}
/* processing → weaving the vault */
.pm-proc{position:fixed;inset:0;z-index:72;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:14px;background:rgba(250,250,248,.9);opacity:0;transition:opacity .4s ease}
.pm-proc.on{opacity:1}
.pm-proc-cube{width:52px;height:52px;border:2.4px solid #16161a;border-radius:12px;
  animation:pm-proc-spin 1.5s cubic-bezier(.6,0,.4,1) infinite}
@keyframes pm-proc-spin{0%{transform:rotate(0) scale(1)}50%{transform:rotate(180deg) scale(.82)}100%{transform:rotate(360deg) scale(1)}}
.pm-proc-txt{font:700 16px ui-sans-serif,system-ui;color:#1c2230}
.pm-proc-sub{font:13px ui-sans-serif,system-ui;color:#8a8f88}
.pm-dots3 i{animation:pm-blink 1.2s infinite both}.pm-dots3 i:nth-child(2){animation-delay:.2s}.pm-dots3 i:nth-child(3){animation-delay:.4s}
@keyframes pm-blink{0%,60%,100%{opacity:.2}30%{opacity:1}}
/* the pinned question — the full ask stays readable above the input */
.pm-bar{flex-direction:column;align-items:stretch;gap:0;padding:0}
.pm-bar-row{display:flex;align-items:center;gap:8px;padding:7px 8px 7px 14px}
#pm-qpin{display:none;font:13px/1.5 ui-sans-serif,system-ui;color:#1c2230;
  padding:10px 14px 9px;border-bottom:1px solid #eef0f2;border-radius:14px 14px 0 0;
  background:#fafbfc}
#pm-qpin.on{display:block;animation:pm-enter-in .4s cubic-bezier(.34,1.5,.4,1) both}
/* during the conversation the pinned question + deck + voice carry the text —
   the transient floating caption is redundant and overlapped the pinned bar */
body.pm-convo #vs-caption { display:none !important; }
/* push-to-talk keycap under the input: HOLD [space] to talk / to interrupt */
.pm-ptt { display:flex; align-items:center; justify-content:center; gap:7px; padding:8px 0 10px;
  font:600 11px ui-monospace,monospace; letter-spacing:.04em; color:#9aa0a8; user-select:none; }
.pm-ptt-lead, .pm-ptt-verb { text-transform:uppercase; }
.pm-key { display:inline-flex; align-items:center; justify-content:center; min-width:58px; height:22px;
  padding:0 10px; border:1.4px solid #c9cdd2; border-bottom-width:3px; border-radius:7px; background:#fff;
  color:#3a3f47; font:700 10.5px ui-monospace,monospace; letter-spacing:.12em; text-transform:uppercase;
  box-shadow:0 1px 0 rgba(22,22,26,.04); }
/* ── composer STATE MACHINE (data-state on .pm-bar) ── */
/* talking — live push-to-talk: dark ring + pulsing key + red dot */
.pm-bar[data-state="talking"] { box-shadow:0 0 0 2px #16161a, 0 6px 24px rgba(22,22,26,.14); }
.pm-bar[data-state="talking"] .pm-key { border-color:#16161a; background:#16161a; color:#fff; animation:pm-ptt-pulse 1s ease-in-out infinite; }
.pm-bar[data-state="talking"] .pm-ptt-lead::before { content:"● "; color:#e0483a; }
.pm-bar[data-state="talking"] .pm-ptt-verb { color:#16161a; }
@keyframes pm-ptt-pulse { 50% { transform:translateY(-1px); } }
/* sending — the answer left; brief processing acknowledgement */
.pm-bar[data-state="sending"] { box-shadow:0 0 0 2px #b6bcc4, 0 6px 24px rgba(22,22,26,.12); }
.pm-bar[data-state="sending"] .pm-send { background:#8a8f88; pointer-events:none; }
.pm-ptt-sending { color:#16161a; }
.pm-ptt-sending::after { content:""; }
/* speaking — the AP holds the floor; input dimmed, space interrupts */
.pm-bar[data-state="speaking"] #pm-say { opacity:.45; }
.pm-bar[data-state="speaking"] .pm-send { opacity:.4; pointer-events:none; }
/* retry — push-to-talk caught nothing */
.pm-ptt-retry { color:#b0663a; font:600 11px ui-monospace,monospace; text-transform:none; }
.pm-ptt-retry .pm-key { min-width:auto; height:17px; padding:0 6px; vertical-align:middle; margin:0 2px; }
.pm-bub.pm-live { opacity:.85; font-style:italic; }
/* mic-permission badge (first run) + live-transcript-in-input state */
.pm-enable-mic { font:700 11px ui-monospace,monospace; letter-spacing:.04em; text-transform:uppercase;
  padding:6px 13px; border:1.4px solid #16161a; border-radius:9px; background:#16161a; color:#fff; cursor:pointer; }
.pm-enable-mic:hover { background:#2e2e34; }
.pm-ptt.pm-ptt-enable { padding-top:10px; }
.pm-ptt-blocked { font:600 11px ui-monospace,monospace; color:#b0663a; }
#pm-say.pm-live-in { color:#16161a; font-style:italic; }

/* the DESIGNER (Kokoro) — lives on the plan-mode grid with the real cube.
   every row is a [label | control] grid; every control fills the SAME width at
   one 40px baseline height, so the panel reads as one clean stack. */
/* full-viewport frame: the two cards sit ABOVE and BELOW the centered cube, the
   avatar living in the gap between them. Container ignores pointer events so the
   empty middle stays click-through; the cards re-enable them. */
.pm-designer { position:fixed; inset:0; z-index:66; pointer-events:none;
  --ctl-h:40px; --line:#e0e4ea; --ink:#16161a;
  display:flex; flex-direction:column; justify-content:space-between; align-items:center;
  padding:4vh 0 3vh; font-family:ui-sans-serif,system-ui,sans-serif; }
/* no card chrome — the controls sit directly on the grid page; only the fields
   that would otherwise show graph lines through them carry a white fill. */
.pmd-card { pointer-events:auto; width:min(500px,94vw);
  background:none; border:0; box-shadow:none; padding:0 24px;
  display:flex; flex-direction:column; gap:13px;
  animation:pm-enter-in .5s cubic-bezier(.34,1.5,.4,1) both; }
.pmd-card:first-child { margin-top:3vh; }
.pmd-card:last-child { margin-bottom:3vh; animation-delay:.06s; }
.pmd-title { font:800 15px ui-sans-serif,system-ui; color:var(--ink); text-align:center; }
.pmd-row { display:grid; grid-template-columns:88px 1fr; align-items:center; gap:16px; }
.pmd-lbl { font:600 10px ui-monospace,monospace; letter-spacing:.09em; text-transform:uppercase; color:#9aa0a8; }

/* NAME — full-width field, same border/height as every other control */
.pmd-nameinput { width:100%; height:var(--ctl-h); box-sizing:border-box; border:1.4px solid var(--line);
  border-radius:11px; padding:0 14px; font:600 14px ui-sans-serif,system-ui; color:var(--ink);
  background:#fff; outline:none; transition:border-color .15s; }
.pmd-nameinput::placeholder { color:#b6bcc4; font-weight:500; }
.pmd-nameinput:focus { border-color:var(--ink); }

/* SHAPE — three buttons split the full width evenly */
.pmd-shapes { display:flex; gap:8px; }
.pmd-shp { flex:1; height:var(--ctl-h); display:grid; place-items:center; font:600 12px ui-monospace,monospace;
  border-radius:11px; cursor:pointer; border:1.4px solid var(--line); background:#fff; color:#4a4f57;
  transition:background .12s,border-color .12s; }
.pmd-shp:hover { border-color:#c4cad2; }
.pmd-shp.on { background:var(--ink); color:#fff; border-color:var(--ink); }

/* COLOR — swatches spread across the full width */
.pmd-swatches { display:flex; justify-content:space-between; align-items:center; }
.pmd-sw { width:26px; height:26px; border-radius:50%; border:1.6px solid #cfd4da; cursor:pointer; padding:0;
  transition:transform .1s; }
.pmd-sw:hover { transform:scale(1.12); }
.pmd-sw.on { box-shadow:0 0 0 2px var(--ink); border-color:#fff; }

/* VOICE + PERSONALITY — full-width picker with centered label */
.pmd-pick { display:flex; align-items:center; gap:2px; height:var(--ctl-h); background:#fff;
  border:1.4px solid var(--line); border-radius:11px; padding:0 6px; }
.pmd-arw { border:0; background:none; cursor:pointer; font:400 18px/1 ui-monospace,monospace; color:#6a6f77;
  width:30px; height:30px; border-radius:8px; flex:none; display:grid; place-items:center; transition:background .12s; }
.pmd-arw:hover { background:#f1f3f6; color:var(--ink); }
.pmd-name { flex:1; text-align:center; font:700 14px ui-sans-serif,system-ui; color:var(--ink); }
.pmd-play { border:0; background:none; cursor:pointer; color:#6a6f77; width:30px; height:30px; border-radius:8px;
  display:grid; place-items:center; flex:none; transition:background .12s; }
.pmd-play:hover { background:#f1f3f6; color:var(--ink); }
.pmd-play svg { width:16px; height:16px; }

.pmd-meet { margin-top:5px; height:48px; font:700 13px ui-monospace,monospace; letter-spacing:.05em;
  border-radius:13px; border:0; background:var(--ink); color:#fff; cursor:pointer; transition:background .12s; }
.pmd-meet:hover { background:#2e2e34; }
end

## the animated slide deck gsap face ca

design :the_animated_slide_deck_gsap_face_ca do
  /* ── the animated slide deck (GSAP) — face card centerpiece, scenes around it ── */
  #obslides { display:none; flex-direction:column; align-items:center; gap:22px;
    width:560px; padding:40px; position:relative; }
  .obskip { position:absolute; top:6px; right:10px; font:11px ui-monospace,monospace;
    color:var(--ink-faint); background:none; border:none; cursor:pointer; -webkit-app-region:no-drag; }
  .obskip:hover { color:var(--ink-2); }
  .slidestage { position:relative; width:480px; height:230px; }
  .slideface { position:absolute; left:50%; top:50%; margin:-57px 0 0 -57px; width:114px; height:114px;
    border-radius:26px; border:1px solid rgba(0,0,0,.12); background:var(--surface); overflow:hidden;
    box-shadow:0 8px 28px rgba(25,35,55,.09); }
  .slidefx { position:absolute; inset:0; pointer-events:none; }
  .slidetext { text-align:center; min-height:78px; max-width:420px; }
  .slidetitle { font:600 20px ui-monospace,SFMono-Regular,Menlo,monospace; color:var(--ink-strong); }
  .slidesub { font:12px/1.6 ui-monospace,monospace; color:var(--ink-dim); margin:8px 0 0; }
  .slidenav { display:flex; align-items:center; gap:16px; }
  .slidenav button { width:34px; height:34px; border-radius:11px; border:1px solid var(--border);
    background:var(--surface); color:var(--ink-2); cursor:pointer; display:flex; align-items:center;
    justify-content:center; -webkit-app-region:no-drag; transition:border-color .15s ease; }
  .slidenav button:hover { border-color:var(--border); }
  .slidenav button svg { width:15px; height:15px; }
  .sldots { display:flex; gap:6px; }
  .sldot { width:6px; height:6px; border-radius:50%; background:var(--border); transition:background .2s ease; }
  .sldot.on { background:var(--purple); }
  /* scene furniture */
  .fxcard { position:absolute; background:var(--surface); border:1px solid var(--border); border-radius:12px;
    padding:10px 12px; font:10.5px/1.5 ui-monospace,monospace; color:var(--ink-2);
    box-shadow:0 3px 12px rgba(25,35,55,.06); white-space:pre; text-align:left; }
  .fxchip { position:absolute; background:var(--surface); border:1px solid var(--border); border-radius:9px;
    padding:5px 10px; font:10px ui-monospace,monospace; color:var(--ink-2);
    box-shadow:0 2px 8px rgba(25,35,55,.05); }
  .fxnode { position:absolute; width:14px; height:14px; border-radius:50%; }
  .fxcaret { display:inline-block; width:6px; height:11px; background:var(--purple);
    vertical-align:-1px; animation:fxblink 1s steps(1) infinite; }
  .fxfile { display:flex; align-items:center; gap:6px; }
  .fxfile img { display:block; }
  .fxchip svg { width:11px; height:11px; vertical-align:-2px; }
  /* "it keeps your word": the live schedule + its stacked fridays */
  .fxlive { width:6px; height:6px; border-radius:50%; background:var(--green); margin-left:auto;
    animation:fxblink 1.6s ease infinite; }
  /* the mini editor — unmistakably A FILE: chrome dots, filename tab, gutter */
  .fxed { position:absolute; width:172px; background:var(--surface); border:1px solid var(--line);
    border-radius:10px; overflow:hidden; text-align:left;
    box-shadow:0 4px 14px var(--border-soft); }
  .fxedhdr { display:flex; align-items:center; gap:4px; background:var(--fill);
    border-bottom:1px solid var(--line); padding:5px 8px;
    font:9px ui-monospace,monospace; color:var(--ink-dim); }
  .fxedhdr img { margin-left:5px; }
  .fxedhdr .dot { width:6px; height:6px; border-radius:50%; background:var(--border); }
  .fxedbody { display:flex; font:9.5px/1.75 ui-monospace,monospace; padding:6px 0; }
  .fxedln { color:var(--border); padding:0 7px; text-align:right; border-right:1px solid var(--fill);
    margin-right:7px; }
  /* pre, never wrap: every edit site owns a whole line, so retyping can't reflow */
  .fxedcode { color:var(--ink-2); white-space:pre; overflow:hidden; padding-right:8px; flex:1; }
  /* diff rows: the two panes speak the same language — red out, green in */
  .fxdiffbody { display:flex; flex-direction:column; padding:6px 0;
    font:9.5px/1.75 ui-monospace,monospace; text-align:left; }
  .fxrow { display:flex; align-items:baseline; padding:0 8px 0 4px; overflow:hidden; }
  .fxg { flex:none; width:11px; text-align:center; font-weight:600; }
  .fxt { white-space:pre; color:var(--ink-2); }
  .fxt.cmt { color:var(--border); }
  .fxt.kw { color:var(--purple); }
  .fxrow.rowdel { background:var(--err-bg); }
  .fxrow.rowdel .fxg { color:var(--red); }
  .fxrow.rowdel .fxg::before { content:"−"; }
  .fxrow.rowdel .fxt { color:var(--red); text-decoration:line-through; }
  .fxrow.rowadd { background:var(--ok-bg); }
  .fxrow.rowadd .fxg { color:var(--green-deep); }
  .fxrow.rowadd .fxg::before { content:"+"; }
  .fxrow.rowadd .fxt { color:var(--green-deep); }
  /* language islands — each language lands as its own little island */
  .fxisle { position:absolute; display:flex; flex-direction:column; align-items:center; gap:2px;
    background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:9px 12px;
    box-shadow:0 4px 12px rgba(25,35,55,.07); }
  .fxisle .finame { font:600 9.5px ui-monospace,monospace; color:var(--ink-strong); }
  .fxisle .fitag { font:8px ui-monospace,monospace; color:var(--ink-fainter); }
  .fxlab { position:absolute; font:9px ui-monospace,monospace; color:var(--ink-fainter); white-space:nowrap; }
  /* the clone grid: the SAME little app, dealt out live for everyone */
  .fxgrid { position:absolute; display:grid; grid-template-columns:repeat(3, 42px); gap:10px; }
  .fxmini { position:relative; width:42px; height:32px; background:var(--surface); border:1px solid var(--line);
    border-radius:7px; box-shadow:0 2px 7px rgba(25,35,55,.06); }
  .fxmini.you { border-color:var(--purple); }
  .fxmini .mbar { position:absolute; left:5px; top:5px; width:14px; height:4px; border-radius:2px; background:var(--purple); }
  .fxmini .mln { position:absolute; left:5px; top:14px; width:26px; height:3px; border-radius:2px; background:var(--line); }
  .fxmini .mln.s { top:21px; width:18px; }
  .fxmini .mdot { position:absolute; right:4px; top:4px; width:5px; height:5px; border-radius:50%; background:var(--green); }
  /* ephemeral sandboxes: sealed (dashed) while running, a green blink when done */
  .fxsbx { position:absolute; width:30px; height:30px; border-radius:9px; background:var(--surface);
    border:1.5px dashed var(--purple); display:flex; align-items:center; justify-content:center;
    box-shadow:0 3px 9px rgba(25,35,55,.07); }
  .fxsbx.done { border-style:solid; border-color:var(--green); }
  /* the derived machinery diffing: old value strikes red, new lands green */
  .difold { color:var(--red) !important; text-decoration:line-through; }
  .difnew { color:var(--green-deep); background:var(--ok-bg); border-radius:3px; padding:0 2px; }
  /* the verdict — the branch your sentence decides */
  .vhold { color:var(--orange); font-weight:600; }
  .vok { color:var(--green-deep); font-weight:600; }
  .vsend { color:var(--blue-deep); font-weight:600; }
  .tick { font:600 9px ui-monospace,monospace; color:var(--green-deep); background:var(--ok-bg);
    border:1px solid var(--green); border-radius:7px; padding:3px 7px; }
  /* the "implemented component" — real HTML/CSS mirroring the sketch's wireframe */
  .fxcomp { position:absolute; right:3%; top:24%; width:132px; height:92px; background:var(--surface);
    border:1px solid var(--border); border-radius:12px; box-shadow:0 4px 14px rgba(25,35,55,.09);
    padding:12px; box-sizing:border-box; }
  .fxcompav { position:absolute; left:12px; top:14px; width:22px; height:22px; border-radius:50%;
    background:linear-gradient(135deg,var(--purple),var(--blue)); }
  .fxcomplines { position:absolute; left:42px; top:16px; display:flex; flex-direction:column; gap:7px; }
  .fxline { height:7px; border-radius:4px; background:var(--border); }
  .fxcompbtn { position:absolute; right:11px; bottom:11px; font:600 9.5px ui-monospace,monospace;
    color:var(--on-accent); background:var(--purple); padding:4px 11px; border-radius:7px; }
  /* mini chat/voice panels — bubbles + dashed tool-call rows, waveform docked */
  .fxchat { position:absolute; width:152px; display:flex; flex-direction:column; gap:6px;
    background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:10px;
    box-shadow:0 4px 14px var(--border-soft); }
  .fxmsg { font:9.5px/1.4 ui-monospace,monospace; padding:4px 8px; border-radius:8px;
    color:var(--ink-2); max-width:92%; }
  .fxmsg.user { align-self:flex-end; background:var(--fill); }
  .fxmsg.bot { align-self:flex-start; background:var(--fill); border:1px solid var(--fill); }
  .fxtool { display:flex; align-items:center; gap:5px; font:9px ui-monospace,monospace;
    color:var(--purple); background:var(--fill); border:1px dashed var(--fill); border-radius:7px; padding:3px 7px; }
  .fxtool svg { width:10px; height:10px; }
  .fxvoice { display:flex; align-items:center; justify-content:center; gap:3px; height:24px;
    background:var(--fill); border-radius:8px; padding:0 8px; }
  .fxvoice .vb { width:3px; height:9px; background:var(--purple); border-radius:2px; display:block; }
  .fxgate { display:flex; gap:12px; justify-content:center; font:600 9.5px ui-monospace,monospace; }
  .fxgate .fxok { color:var(--green); display:inline-block; }
  .fxgate .fxno { color:var(--red); }
  /* prose spans the parser lights up, each in its node's color */
  .astp { border-radius:4px; padding:0 2px; border-bottom:2px solid transparent; }
  .fxfile svg { width:12px; height:12px; }
  /* the science slide: portrait cards for the people whose math runs the harness */
  .fxperson { display:flex; flex-direction:column; align-items:center; gap:4px;
    font:9px ui-monospace,monospace; color:var(--ink-dim); }
  .fxpimg { width:46px; height:46px; border-radius:11px; object-fit:cover;
    filter:grayscale(1); border:1px solid var(--border); }
  /* the evolution vignette: mini variant face cards + the survivor's check */
  .fxevo { position:absolute; width:38px; height:38px; border-radius:10px; background:var(--surface);
    border:1px solid var(--border); box-shadow:0 3px 10px var(--border-soft);
    display:flex; align-items:center; justify-content:center; }
  .fxevo.won { border-color:var(--green); box-shadow:0 0 0 3px rgba(106,168,79,.18); }
  .fxevo.won::after { content:"✓"; position:absolute; top:-7px; right:-7px; width:14px; height:14px;
    border-radius:50%; background:var(--green); color:var(--on-accent); font:600 9px/14px ui-monospace,monospace;
    text-align:center; }
  .fxcred { position:absolute; left:50%; bottom:0; transform:translateX(-50%); display:flex;
    align-items:center; gap:5px; font:8.5px ui-monospace,monospace; color:var(--ink-fainter); white-space:nowrap; }
  .fxcred img { width:14px; height:14px; border-radius:50%; object-fit:cover;
    filter:grayscale(1); border:1px solid var(--line); }
  @keyframes fxblink { 50% { opacity:0; } }
end

## nexus choice

design :nexus_choice do
  /* ── nexus choice: radio-card accordion + machine setup (custom components) ── */
  .nx-stack { display:flex; flex-direction:column; gap:16px; width:100%; }
  .nx-option { position:relative; border:1.6px solid #e2e6ec; border-radius:15px; background:#fff;
    transition:border-color .18s ease, box-shadow .18s ease; }
  .nx-option.open { border-color:#16161a; box-shadow:0 3px 14px rgba(20,30,50,.08); }
  .nx-badge { position:absolute; top:-9px; left:16px; background:#16161a; color:#fff;
    font:600 9.5px ui-monospace,monospace; letter-spacing:.04em; text-transform:uppercase;
    padding:3px 8px; border-radius:6px; z-index:1; }
  .nx-head { display:flex; align-items:center; gap:13px; width:100%; padding:18px;
    background:none; border:0; cursor:pointer; text-align:left; }
  .nx-ico { display:grid; place-items:center; width:34px; height:34px; border-radius:10px;
    background:#f4f6f8; color:#16161a; flex:none; }
  .nx-ico svg { width:16px; height:16px; }
  .nx-title { font:600 13.5px ui-monospace,monospace; color:#1c2230; flex:1; }
  .nx-meta { font:12px ui-monospace,monospace; color:#8a8f88; }
  .nx-radio { width:16px; height:16px; border-radius:50%; border:1.6px solid #c9cfd8; flex:none;
    transition:border-color .15s ease, box-shadow .15s ease; }
  .nx-option.open .nx-radio { border-color:#16161a; box-shadow:inset 0 0 0 4px #16161a; }
  .nx-body { display:none; flex-direction:column; gap:14px; padding:2px 20px 22px 65px; }
  .nx-option.open .nx-body { display:flex; }
  .nx-line { font:12px/1.55 ui-monospace,monospace; color:#6a6f68; margin:0; }
  .nx-row { display:flex; gap:8px; align-items:center; }
  .nx-row .obinput { flex:1; margin:0; }

  /* existing-nexus picks */
  .nx-pick { display:flex; align-items:center; gap:10px; width:100%; padding:11px 12px;
    border:1.4px solid #e2e6ec; border-radius:11px; background:#fff; cursor:pointer; text-align:left; }
  .nx-pick:hover { border-color:#b9c2cd; }
  .nx-pick.sel { border-color:#16161a; box-shadow:inset 0 0 0 1px #16161a; }
  .nx-pick-name { font:600 12.5px ui-monospace,monospace; color:#1c2230; flex:1; }
  .nx-chips { display:flex; gap:5px; }
  .nx-chip { font:10px ui-monospace,monospace; font-style:normal; color:#6a6f68;
    background:#f4f6f8; border-radius:6px; padding:2.5px 7px; }
  .nx-go { font:11.5px ui-monospace,monospace; color:#245cc0; }

  /* machine setup: tier cards · credit chips · toggle */
  .nx-lbl { font:600 10px ui-monospace,monospace; letter-spacing:.07em; text-transform:uppercase;
    color:#8a8f88; margin-top:8px; }
  .nx-tiers { display:grid; grid-template-columns:repeat(auto-fit,minmax(108px,1fr)); gap:10px; }
  .nx-tier { display:flex; flex-direction:column; gap:4px; align-items:flex-start; padding:13px 14px;
    border:1.4px solid #e2e6ec; border-radius:11px; background:#fff; cursor:pointer; }
  .nx-tier:hover { border-color:#b9c2cd; }
  .nx-tier.sel { border-color:#16161a; box-shadow:inset 0 0 0 1px #16161a; }
  .nx-tier b { font:600 12px ui-monospace,monospace; color:#1c2230; }
  .nx-price { font:14px ui-monospace,monospace; color:#16161a; }
  .nx-price i { font-style:normal; font-size:10.5px; color:#8a8f88; }
  .nx-spec { font:10px ui-monospace,monospace; color:#8a8f88; }
  .nx-chipsrow { display:flex; gap:9px; flex-wrap:wrap; }
  .nx-chipbtn { font:600 12px ui-monospace,monospace; padding:8px 16px; border-radius:9px;
    border:1.4px solid #e2e6ec; background:#fff; color:#1c2230; cursor:pointer; }
  .nx-chipbtn:hover { border-color:#b9c2cd; }
  .nx-chipbtn.sel { border-color:#16161a; background:#16161a; color:#fff; }
  .nx-toggle { display:flex; align-items:center; gap:11px; font:12px/1.7 ui-monospace,monospace;
    color:#1c2230; cursor:default; margin-top:6px; }
  .nx-switch { display:inline-block; width:34px; height:20px; border-radius:11px; background:#dfe3e9;
    position:relative; cursor:pointer; flex:none; transition:background .18s ease; }
  .nx-switch i { position:absolute; top:2px; left:2px; width:16px; height:16px; border-radius:50%;
    background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.2); transition:left .18s ease; }
  .nx-switch.on { background:#16161a; }
  .nx-switch.on i { left:16px; }
  .nx-mini { width:40px; font:12px ui-monospace,monospace; text-align:center; padding:3px 4px;
    border:1px solid #d6dbe2; border-radius:7px; }
  .nx-foot { display:flex; align-items:center; justify-content:space-between; gap:14px; width:100%; margin-top:4px; }
  .nx-status { font:12px ui-monospace,monospace; color:#3f7a52; display:flex; align-items:center; gap:6px; }
  .nx-status svg { width:14px; height:14px; }
  .nx-step { font:600 10px ui-monospace,monospace; letter-spacing:.09em; text-transform:uppercase;
    color:#8a8f88; background:#f4f6f8; border-radius:7px; padding:4px 10px; align-self:flex-start; }

  /* quiet text links (the de-emphasized escape hatches under the confirm card) */
  .nx-quiet { font:11.5px ui-monospace,monospace; color:#8a8f88; text-decoration:underline;
    text-underline-offset:2.5px; text-decoration-color:#c9cfd8; cursor:pointer; }
  .nx-quiet:hover { color:#1c2230; text-decoration-color:#1c2230; }
  .nx-quietrow { display:flex; gap:18px; flex-wrap:wrap; margin-top:2px; }
  .nx-picks { display:flex; flex-direction:column; gap:8px; }
  .nx-offline { color:#8a8f88; }

  /* ghost skeleton — fixed height, replaced in place (no layout jump) */
  .nx-ghost { height:118px; display:grid; place-items:center; position:relative; overflow:hidden; }
  .nx-ghost::after { content:""; position:absolute; inset:0;
    background:linear-gradient(100deg, transparent 32%, rgba(20,30,50,.05) 50%, transparent 68%);
    background-size:220% 100%; animation:nx-shimmer 1.4s linear infinite; }
  @keyframes nx-shimmer { from { background-position:180% 0; } to { background-position:-80% 0; } }
  .nx-ghosttext { font:12px ui-monospace,monospace; color:#8a8f88; }
end

## requisition

design :requisition do
/* ── FORM AP-7 — the requisition sheet: a straight-faced government form.
   Mounted ON the plan stage (over the white grid) — the host is transparent
   so the grid shows through; only the sheet is a paper card. ── */
#obreq{position:absolute;inset:0;display:flex;align-items:flex-start;justify-content:center;
  overflow-y:auto;padding:44px 16px 60px;z-index:20;background:transparent;pointer-events:auto}
/* standalone/dev fallback (over the beige onboard overlay) paints its own grid */
#obreq.rq-standalone{background:
  linear-gradient(transparent 23px, rgba(22,22,26,.035) 24px) 0 0/24px 24px,
  linear-gradient(90deg, transparent 23px, rgba(22,22,26,.035) 24px) 0 0/24px 24px}
/* entrance: the sheet drops onto the grid; exit: it lifts off (character cue) */
#obreq .rq-sheet{opacity:0;transform:translateY(-18px) rotate(-.3deg) scale(.985);
  transition:opacity .5s ease, transform .6s cubic-bezier(.34,1.4,.4,1)}
#obreq.rq-in .rq-sheet{opacity:1;transform:rotate(-.3deg) scale(1)}
#obreq.rq-lift{transition:opacity .5s ease}
#obreq.rq-lift .rq-sheet{opacity:0;transform:translateY(-40px) rotate(-1.4deg) scale(.94);
  transition:opacity .55s ease, transform .6s cubic-bezier(.5,0,.75,0)}
.rq-sheet{width:min(680px,94vw);background:#fdfdfa;border:1.6px solid #16161a;border-radius:3px;
  box-shadow:6px 8px 0 rgba(22,22,26,.14);padding:26px 30px 22px;
  font:13px/1.45 ui-monospace,SFMono-Regular,monospace;color:#26262b;transform:rotate(-.3deg)}
.rq-head{display:flex;align-items:center;gap:14px;border-bottom:2.5px solid #16161a;padding-bottom:12px}
.rq-seal{width:44px;height:44px;border:2.5px double #16161a;border-radius:50%;display:flex;
  align-items:center;justify-content:center;font-weight:800;font-size:15px;flex:none}
.rq-agency{flex:1;display:flex;flex-direction:column;gap:2px}
.rq-agency b{font-size:15px;letter-spacing:.12em}
.rq-agency span{font-size:10.5px;color:#6a6f68}
.rq-omb{font-size:9.5px;color:#8a8f88;text-align:right;line-height:1.5}
.rq-title{text-align:center;font-weight:800;font-size:17px;letter-spacing:.28em;margin:16px 0 4px}
.rq-sub{text-align:center;font-size:11px;color:#6a6f68;font-style:italic;margin-bottom:16px}
.rq-sec{border:1.4px solid #16161a;border-radius:2px;padding:10px 14px 12px;margin-bottom:12px}
.rq-sec>b{font-size:11.5px;letter-spacing:.08em}
.rq-sec>em{font-size:10px;color:#8a8f88}
.rq-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px 10px;margin-top:9px}
.rq-row{display:flex;align-items:center;gap:12px;margin-top:9px;flex-wrap:wrap}
.rq-lbl{width:118px;flex:none;font-size:11px;color:#4a4f48}
.rq-ck{display:inline-flex;align-items:center;gap:6px;font-size:11.5px;cursor:pointer;user-select:none}
.rq-ck input{position:absolute;opacity:0;width:0}
.rq-ck i{width:13px;height:13px;border:1.6px solid #16161a;flex:none;display:inline-block;position:relative;background:#fff}
.rq-ck.rq-rd i{border-radius:50%}
.rq-ck input:checked+i::after{content:"✕";position:absolute;inset:-4px 0 0 0;font:800 13px/1 ui-monospace,monospace;
  color:#16161a;text-align:center}
.rq-ck.rq-rd input:checked+i::after{content:"●";font-size:9px;inset:0;line-height:11px}
.rq-line{border:0;border-bottom:1.6px solid #16161a;background:transparent;flex:1;min-width:200px;
  font:inherit;padding:2px 4px;outline:none}
.rq-wide{width:100%;margin-top:8px}
.rq-sig{display:flex;gap:34px;margin:18px 4px 6px}
.rq-sig>div{flex:1;display:flex;flex-direction:column}
.rq-sig span{border-bottom:1.6px solid #16161a;min-height:26px;padding:0 6px 2px}
.rq-sig label{font-size:9.5px;color:#8a8f88;margin-top:3px}
.rq-cursive{font-family:"Snell Roundhand","Segoe Script",cursive;font-size:19px}
.rq-fine{font-size:9px;color:#9a9f98;margin:8px 4px 0;line-height:1.6}
.rq-actions{display:flex;align-items:center;justify-content:flex-end;gap:16px;margin-top:14px;min-height:44px}
.rq-btn{font:700 12.5px ui-monospace,monospace;letter-spacing:.1em;padding:11px 20px;cursor:pointer;
  background:#16161a;color:#fff;border:1.6px solid #16161a;border-radius:2px}
.rq-btn:hover{background:#2e2e34}
.rq-btn:disabled{opacity:.55;cursor:default}
.rq-stamp{display:none}
.rq-stamp.on{display:block;font:800 15px ui-monospace,monospace;letter-spacing:.24em;color:#b3372f;
  border:2.5px solid #b3372f;border-radius:3px;padding:5px 12px;transform:rotate(-7deg);
  animation:rq-slam .28s cubic-bezier(.2,2.4,.4,1)}
.rq-stamp.on.ok{color:#2c6e49;border-color:#2c6e49}
.rq-note{font-size:11.5px;color:#26262b;text-align:right;max-width:380px}
@keyframes rq-slam{from{transform:rotate(-7deg) scale(2.1);opacity:0}to{transform:rotate(-7deg) scale(1);opacity:1}}
end

