    var flip = false, n = 0;
    waveTimer = later(setInterval(function () {
      flip = !flip;
      setHand(hands.r, { hr: (rBase + (flip ? 16 : -16)) + "deg" });
      if (both) setHand(hands.l, { hr: (lBase + (flip ? -16 : 16)) + "deg" });
      if (++n > 7) hideHands();
    }, 170));
  }
