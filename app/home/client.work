# The app — DOM, then every script in load order

One file so emission order is EXACT (within-file order is preserved): the
shell DOM + vendor libs first, then the performer and the body, then every
numbered script in the precise order the app boots — reproducing app.html's
load sequence so nothing references a global or a node before it exists.

## shell

client :shell do
  <!doctype html>
  <meta charset="utf-8">
  <title>autopoet</title>
  <style>:root{--chrome-display:none}</style>
  <script>
    // Custom traffic-light chrome renders ONLY in the desktop's frameless webview:
    // there the wx frame draws no native title bar, so the PAGE draws its own. The
    // desktop loads the shell with ?frameless=1 (Autopoet.Window); a plain browser
    // tab — e.g. the cloud-login callback landing on localhost — has no flag, so the
    // stoplights stay hidden (no fake, non-functional controls in a browser). Runs
    // synchronously during parse (no flash) and survives location.reload() (which
    // preserves the query string). Replaces the old serve-time __CHROME__ substitution
    // that Autopoet.Control did before the nexus migration served the page verbatim.
    // page-side truth → the app log: the desktop webview has no visible console, so
    // uncaught errors and capability gaps were invisible from outside. Every uncaught
    // error/rejection and the boot capability probe land at POST /client/log.
    (function () {
      var plog = function (m) { try { fetch("/client/log", { method: "POST", body: String(m).slice(0, 480) }); } catch (_) {} };
      window.addEventListener("error", function (e) { plog((e.message || "error") + " @ " + (e.filename || "?") + ":" + (e.lineno || 0)); });
      window.addEventListener("unhandledrejection", function (e) { plog("unhandled: " + (e.reason && (e.reason.message || e.reason))); });
      plog("boot mediaDevices=" + !!(navigator.mediaDevices && navigator.mediaDevices.getUserMedia) + " ua-webview=" + !/Chrome|Firefox/.test(navigator.userAgent));
    })();
    if (new URLSearchParams(location.search).has("frameless")) {
      document.documentElement.style.setProperty("--chrome-display", "flex");
      // native-fullscreen etiquette: macOS hides traffic lights in fullscreen, so the
      // custom set must vanish too (and return on exit). The webview fills the frame,
      // so "viewport == whole screen" IS the fullscreen signal — no native plumbing.
      const chromeFs = () => document.documentElement.style.setProperty(
        "--chrome-display",
        (window.innerHeight >= screen.height && window.innerWidth >= screen.width) ? "none" : "flex");
      window.addEventListener("resize", chromeFs);
      window.addEventListener("DOMContentLoaded", chromeFs);
    }
  </script>

