    var stamps = "";
    var R = 1.6, D8 = R * 0.7071;
    [[R, 0], [-R, 0], [0, R], [0, -R], [D8, D8], [D8, -D8], [-D8, D8], [-D8, -D8]]
      .forEach(function (o) {
