// gray is RESERVED for the built-in system cluster — the palette below never deals it.
// It's a THEME VAR (light gray on light, deep gray on dark) so the emoji reads on both.
const CLPAL = ["#8e7cc3", "#6aa84f", "#e07a5f", "#4a90d9", "#d96ba0", "#2aa198", "#c9a04e"];
const SYSTEM_GRAY = "var(--sys-node)";

// ── the built-in "system" cluster: everything the app ships (guide pages, the
// agents registry, the oota library, infra agents) grouped as ONE gray node,
// expandable like any cluster — default content is visible-but-compact, never
