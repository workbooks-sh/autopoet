    var src = actx.createBufferSource();
    src.buffer = clip.buffer;
    src.connect(analyser);
    clipNow = { src: src, t0: actx.currentTime };
    src.onended = function () { if (clipNow && clipNow.src === src) clipNow = null; if (onended) onended(); };
    src.start();
