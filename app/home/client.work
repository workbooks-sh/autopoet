  return c;
}
const clusterById = id => clusters.find(c => c.id === id);
function removeCluster(id) {
  const c = clusterById(id);
  // dissolving the built-in system cluster is respected forever (tombstone) —
  // it never re-seeds itself behind the owner's back
  if (c && c.builtin) localStorage.setItem("ap-syscluster-dissolved", "1");
  clusters = clusters.filter(x => x.id !== id);
