# Autopoet.WorldGraph

  The autopoet's world as a graph — the data behind the desktop UI's force view.

The module verbatim, now authored as `.work` — its Elixir source lives inside
a beam-compiled `server` block instead of a scattered `.ex` file.

defmodule Autopoet.WorldGraph do
  @moduledoc """
  The autopoet's world as a graph — the data behind the desktop UI's force view.
  Center: the self (the face). Around it: the body's `.work` docs (with real
  backlink edges between them, from the parser's refs), the agents, recent
  proposals (colored by verdict), and pending requests. Every node carries a
  short `detail` for the click panel. JSON here is a genuine HTTP boundary
  (same class as Nexus.Desktop's discovery file) — never config.
  """

  # Node classes hidden from the graph BY DEFAULT (genesis invariant I3, wb-h0tjs.1):
  # infrastructure exists and runs, but the visible world is the user's world. Shipped
  # server-side so every frontend (fresh browser profile, voice surface) inherits it.
  @default_hidden ~w(guide system library)

  # Infra agents the app itself seeds/uses — plumbing, not crew. The user's own agents
  # (shopkeeper, producer, …) stay visible: they ARE the product's face.
  @system_agents ~w(researcher intake_scout)

  @doc """
  The SINGLE source of truth for a body doc's graph class (genesis I2/I3):
  `guide` (reference pages), `system` (machinery — the agents registry, intake
  plumbing), `doc` (the user's world — visible).
  """
  def classify(rel) do
    cond do
      String.contains?(rel, "guide/") -> "guide"
      rel == "agents.work" or String.starts_with?(rel, "intake/") -> "system"
      true -> "doc"
    end
  end

  def payload do
    root = Nexus.Paths.data_dir()

    docs =
      Path.wildcard(Path.join(root, "**/*.work"))
      |> Enum.reject(&String.contains?(&1, "/.nexus/"))

    workspaces = workspaces(root)
    ws_slugs = MapSet.new(workspaces, & &1.slug)

    doc_nodes =
      for f <- docs,
          rel = Path.relative_to(f, root),
          # index.work files are STRUCTURE (the manifest, a workspace's front
          # matter), not content — they never render as world nodes
          Path.basename(rel) != "index.work" do
        {ws, folder} = place(rel, ws_slugs)

        %{
          id: "doc:#{rel}",
          label: Path.basename(rel, ".work"),
          type: classify(rel),
          path: rel,
          workspace: ws,
          folder: folder,
          detail: f |> File.read!() |> String.slice(0, 4000)
        }
      end

    by_base =
      Map.new(doc_nodes, fn n -> {n.label, n.id} end)

    ref_links =
      for f <- docs,
          rel = Path.relative_to(f, root),
          node <- safe_parse(f),
          ref <- Map.get(node, :refs, []),
          String.starts_with?(ref, "[["),
          target = ref |> String.trim_leading("[[") |> String.trim_trailing("]]"),
          dst = Map.get(by_base, target),
          dst != "doc:#{rel}",
          uniq: true do
        %{source: "doc:#{rel}", target: dst, kind: "ref"}
      end

    agent_nodes =
      for node <- Nexus.Agent.all() do
        d = safe_def(node)

        %{
          id: "agent:#{node.name}",
          label: to_string(node.name),
          type: if(to_string(node.name) in @system_agents, do: "system", else: "agent"),
          detail:
            "model: #{inspect(d[:model])}\ngrant: #{inspect(d[:grant])}\nmanagement: #{Nexus.Agent.management(node)}\n\n#{String.slice(d[:system] || "", 0, 400)}"
        }
      end

    # Proposals are EPHEMERAL — a pending inbox, not durable world state. Resolved
    # ones live on disk for revert/audit but never clutter the graph (an accepted
    # proposal already IS body content; a rejected one's trace is in the capture log).
    proposal_nodes =
      for {id, status} <- Autopoet.Proposals.pending() do
        base = Path.join(Autopoet.Proposals.dir(), id)
        target = case File.read(Path.join(base, "target")) do
          {:ok, t} -> String.trim(t)
          _ -> "?"
        end

        item = case File.read(Path.join(base, "item.txt")) do
          {:ok, t} -> String.slice(t, 0, 400)
          _ -> ""
        end

        files =
          Map.keys(Autopoet.Proposals.changes(id)) ++
            Enum.map(Map.keys(Autopoet.Proposals.appends(id)), &("append → " <> &1))

        %{
          id: "prop:#{id}",
          # human-readable: what it touches + its state, not the raw hash
          label: "#{target} · #{status}",
          type: "proposal",
          status: status,
          detail: "proposal #{id}\nstatus: #{status}\nfiles: #{Enum.join(files, ", ")}\n\n#{item}"
        }
      end

    # VAULT items never render in the world (inform 6 stays compiled): a request
    # targeting a notes/*.md mirror is plumbing between lanes, not world state —
    # unfiltered, the intake's note mirror showed as N duplicate "note" nodes
    request_nodes =
      Autopoet.Requests.pending()
      |> Enum.reject(fn r ->
        t = to_string(r.target)
        String.starts_with?(t, "notes/") or String.ends_with?(t, ".md")
      end)
      |> Enum.with_index()
      |> Enum.map(fn {r, i} ->
        %{
          id: "req:#{i}",
          label: to_string(r.target),
          type: "request",
          detail: String.slice(to_string(r.change), 0, 500)
        }
      end)

    self_node = %{id: "self", label: "autopoet", type: "self", detail: self_detail()}

    # the OOTA recipe library, as ONE node (not its 472 files) — a readable reference the agent
    # reaches at /work/oota. Omitted when the library isn't seeded.
    oota_nodes = oota_node()

    nodes = [self_node | doc_nodes ++ agent_nodes ++ oota_nodes ++ proposal_nodes ++ request_nodes]

    # everything tethers to the self unless it already hangs off another doc
    ref_targets = MapSet.new(ref_links, & &1.target)

    tethers =
      for n <- tl(nodes),
          n.type != "doc" or not MapSet.member?(ref_targets, n.id) do
        %{source: "self", target: n.id, kind: "tether"}
      end

    # system_types: the same plumbing classes, for the client's built-in
    # "system" cluster — grouped into ONE gray expandable node rather than
    # hidden outright (default_hidden stays the server contract for evals
    # and alternate frontends). workspaces: the declared/discovered subtrees —
    # the client seeds an auto-cluster per workspace (docs carry `workspace`).
    %{nodes: nodes, links: tethers ++ ref_links,
      default_hidden: @default_hidden, system_types: @default_hidden,
      workspaces: workspaces}
  end

  # The user's WORKSPACES: declared in the manifest (`deploy workspaces=`,
  # the Workbooks convention) UNION discovered — any top-level folder carrying
  # its own index.work is a workspace even before the manifest names it.
  # The world organizes by these; folders live INSIDE them.
  def workspaces(root) do
    declared =
      for w <- List.wrap(Nexus.Config.workspaces()) do
        %{slug: w.id, title: w.name, emoji: w[:icon]}
      end

    discovered =
      for dir <- Path.wildcard(Path.join(root, "*/index.work")),
          slug = dir |> Path.dirname() |> Path.basename(),
          not String.starts_with?(slug, "."),
          slug not in ~w(guide intake notes) do
        %{slug: slug, title: title_of(dir, slug), emoji: nil}
      end

    (declared ++ discovered) |> Enum.uniq_by(& &1.slug)
  end

  defp title_of(index_file, slug) do
    case File.read(index_file) do
      {:ok, src} ->
        case Regex.run(~r/^#\s+(.+)$/m, src) do
          [_, t] -> String.trim(t)
          _ -> slug
        end

      _ ->
        slug
    end
  end

  # a doc's place in the world: {workspace_slug | nil, folder_path | nil} —
  # folder is the subpath BETWEEN the workspace and the file (sub-cluster seam)
  defp place(rel, ws_slugs) do
    case Path.split(rel) do
      [top | rest] when rest != [] ->
        if MapSet.member?(ws_slugs, top) do
          case Enum.drop(rest, -1) do
            [] -> {top, nil}
            folders -> {top, Enum.join(folders, "/")}
          end
        else
          {nil, nil}
        end

      _ ->
        {nil, nil}
    end
  end

  @doc "Node types hidden by default (I3) — exposed for evals and alternate frontends."
  def default_hidden, do: @default_hidden

  defp oota_node do
    dir = Autopoet.Oota.dest()

    if File.dir?(dir) do
      files = Path.wildcard(Path.join(dir, "**")) |> Enum.count(&File.regular?/1)

      [
        %{
          id: "oota",
          label: "oota library",
          type: "library",
          detail:
            "OOTA recipe library — #{files} media/document tool recipes, readable in-sandbox at " <>
              "/work/oota (tools/steps, docs, examples, components, wrappers). READ a recipe for the " <>
              "approach, then re-express it in the wasm-native toolchain (JS/C/C++/Go/Rust). Python " <>
              "recipes are reference-only. Never a host process."
        }
      ]
    else
      []
    end
  end

  defp self_detail do
    st = Nexus.Autopoet.Worker.status()
    hebb = Autopoet.Shadow.Hebb.stats()
    surprise = Autopoet.Shadow.Surprise.stats()

    "heartbeat: #{if st.armed, do: "armed (#{inspect(st.spec)})", else: "disarmed"}\n" <>
      "memory: #{div(:erlang.memory(:total), 1_048_576)}MB\n" <>
      "captured events: #{Autopoet.Capture.count()}\n" <>
      "shadow: #{hebb.events} events, #{hebb.edges} pathways; surprise alarms: #{surprise.alarms}"
  end

  defp safe_parse(f) do
    Nexus.Literate.parse(File.read!(f))
  rescue
    _ -> []
  end

  defp safe_def(node) do
    Nexus.Agent.def_from_unit(node)
  rescue
    _ -> %{}
  end
end
