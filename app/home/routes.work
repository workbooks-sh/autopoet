# App routes — the vault, the body, the avatar

The HTTP surface for the workspace + editor + avatar, migrated from the legacy
`Autopoet.Control` Plug into idiomatic `server`-block routes the nexus serves.
Handlers are `req`-style: `req.query`/`req.body`/`req.raw_body` in, a JSON map or
`{status, content_type, bytes}` out. On this trusted desktop nexus the routes are
`:public` (one operator); the cloud tenant layers auth on top.

server :vault do
  route "GET /notes/tree.json", :notes_tree, auth: :public
  route "GET /notes/file", :notes_file, auth: :public
  route "POST /notes/save", :notes_save, auth: :public
  route "GET /body/file", :body_file, auth: :public
  route "POST /body/save", :body_save, auth: :public
  route "GET /avatar/mouths.json", :avatar_mouths, auth: :public
  route "GET /micons.json", :micons, auth: :public

  # the nexus router wraps a BARE list return in %{result: …}; the client wants
  # the array directly, so JSON-encode list payloads ourselves.
  def notes_tree(_req), do: {200, "application/json", Jason.encode!(Autopoet.Notes.tree())}

  def notes_file(req) do
    case Autopoet.Notes.read(req.query["path"] || "") do
      {:ok, content} -> {200, "text/plain; charset=utf-8", content}
      _ -> {404, %{error: "no such note"}}
    end
  end

  def notes_save(req) do
    Autopoet.Notes.write(req.query["path"], to_string(req.raw_body || ""))
    %{ok: true}
  end

  def body_file(req) do
    case Autopoet.Body.read(req.query["path"] || "") do
      {:ok, content} -> {200, "text/plain; charset=utf-8", content}
      _ -> {404, %{error: "no such file"}}
    end
  end

  def body_save(req) do
    path = req.query["path"]
    Autopoet.Body.write(path, to_string(req.raw_body || ""))
    Autopoet.Log.puts("body: human edited #{path} directly")
    %{ok: true}
  end

  def avatar_mouths(_req), do: Autopoet.Avatar.mouths()

  def micons(_req) do
    dir = Path.join([Autopoet.Discovery.home(), "app", "home", "static", "micons"])

    names =
      case File.ls(dir) do
        {:ok, files} ->
          files |> Enum.filter(&String.ends_with?(&1, ".svg")) |> Enum.map(&String.trim_trailing(&1, ".svg")) |> Enum.sort()

        _ ->
          []
      end

    %{icons: names}
  end
end

## Studio — voices, history, chat, profile

server :studio do
  route "GET /voices/traits.json", :voices_traits, auth: :public
  route "POST /voices/default", :voices_default, auth: :public
  route "GET /history/log.json", :history_log, auth: :public
  route "GET /history/diff.json", :history_diff, auth: :public
  route "GET /profile", :profile, auth: :public
  route "GET /chat/sessions.json", :chat_sessions, auth: :public
  route "POST /chat/new", :chat_new, auth: :public
  route "POST /intake/start", :intake_start, auth: :public
  route "POST /speak/stop", :speak_stop, auth: :public

  def voices_traits(_req) do
    pinned = Autopoet.VoiceRoster.pinned()
    verdicts = Autopoet.VoiceRoster.verdicts()

    for name <- Autopoet.VoicePersonas.names() ++ pinned,
        verdicts[name] != "rejected",
        t = Autopoet.VoiceRoster.traits(name),
        t != nil,
        File.exists?(Path.join(Autopoet.VoiceRoster.takes_dir(), name <> ".wav")),
        into: %{},
        do: {name, Map.put(t, "kind", if(name in pinned, do: "pinned", else: "designed"))}
  end

  def voices_default(req) do
    engine = req.query["engine"]
    name = Path.basename(req.query["name"] || "")

    valid =
      (engine == "qwen-clone" and name in Autopoet.VoiceRoster.pinned()) or
        (engine == "qwen-design" and Autopoet.VoicePersonas.description(name) != nil)

    if valid do
      path = Path.join([Autopoet.Discovery.home(), "data", "voices", "default"])
      File.mkdir_p!(Path.dirname(path))
      File.write!(path, "#{engine} #{name}\n")
      %{ok: true, engine: engine, name: name}
    else
      {400, %{error: "unknown voice"}}
    end
  end

  def history_log(_req), do: {200, "application/json", Jason.encode!(Autopoet.History.log())}
  def history_diff(req), do: %{files: Autopoet.History.diff(req.query["rev"] || "@")}
  def profile(_req), do: {200, "text/plain; charset=utf-8", Autopoet.Profile.render()}
  def chat_sessions(_req), do: {200, "application/json", Jason.encode!(Autopoet.Chat.sessions())}
  def chat_new(_req), do: {200, "text/plain; charset=utf-8", Autopoet.Chat.new() <> "\n"}
  def intake_start(_req), do: {200, "text/plain; charset=utf-8", "#{Autopoet.Intake.start()}\n"}

  def speak_stop(_req) do
    Autopoet.Voice.stop()
    {200, "text/plain; charset=utf-8", "quiet\n"}
  end
end

## App misc — auth state, deck, affect, graph

server :app_misc do
  route "GET /auth/state.json", :auth_state, auth: :public
  route "POST /auth/onboarding/done", :onboarding_done, auth: :public
  route "POST /auth/onboarding/reset", :onboarding_reset, auth: :public
  route "POST /voice/affect", :voice_affect, auth: :public
  route "POST /voice/deck/new", :deck_new, auth: :public
  route "POST /voice/deck/add", :deck_add, auth: :public
  route "GET /graph.json", :graph_json, auth: :public
  route "POST /profile/reset", :profile_reset, auth: :public

  defp deck_dir, do: Path.join([Autopoet.Discovery.home(), "data", "decks"])
  defp deck_file, do: Path.join(deck_dir(), "current.md")

  def auth_state(_req) do
    s = Autopoet.Auth.state()
    real = Map.new(Autopoet.Connections.all(), &{&1, true})

    %{
      authenticated: s.authenticated,
      onboarded: s.onboarded,
      user: s.user,
      connections: Map.merge(Map.get(s, :connections, %{}), real)
    }
  end

  def onboarding_done(_req) do
    Autopoet.Auth.complete_onboarding()
    %{ok: true}
  end

  def onboarding_reset(_req) do
    Autopoet.Auth.reset_onboarding()
    %{ok: true}
  end

  def voice_affect(req) do
    case Autopoet.Affect.classify(to_string(req.raw_body || "")) do
      {:ok, top} -> {200, "text/plain; charset=utf-8", Enum.map_join(top, "\n", fn {l, s} -> "#{l} #{s}" end)}
      _ -> {200, "text/plain; charset=utf-8", ""}
    end
  end

  def deck_new(_req) do
    File.mkdir_p!(deck_dir())

    case File.stat(deck_file()) do
      {:ok, %{mtime: mt}} ->
        stamp = mt |> NaiveDateTime.from_erl!() |> NaiveDateTime.to_iso8601() |> String.replace(":", "-")
        File.rename(deck_file(), Path.join(deck_dir(), "deck-#{stamp}.md"))

      _ ->
        :ok
    end

    %{ok: true}
  end

  def deck_add(req) do
    slide = String.trim(to_string(req.raw_body || ""))
    File.mkdir_p!(deck_dir())

    deck =
      case File.read(deck_file()) do
        {:ok, prior} when prior != "" -> prior <> "\n---\n" <> slide
        _ -> slide
      end

    File.write!(deck_file(), deck)
    %{ok: true}
  end

  def graph_json(_req), do: {200, "application/json", Jason.encode!(Autopoet.WorldGraph.payload())}

  def profile_reset(_req) do
    Autopoet.Profile.clear()
    %{ok: true}
  end
end

## Window, chat, proposals, cloud status

server :app_ctl do
  route "GET /health", :health, auth: :public
  route "POST /win/:action", :win, auth: :public
  route "GET /chat/transcript", :chat_transcript, auth: :public
  route "POST /proposal/:id/accept", :proposal_accept, auth: :public
  route "POST /proposal/:id/reject", :proposal_reject, auth: :public
  route "GET /cloud/status.json", :cloud_status, auth: :public
  route "GET /cloud/machine.json", :cloud_machine, auth: :public

  def health(_req), do: {200, "text/plain; charset=utf-8", "ok"}

  def win(req) do
    action = req.params["action"] || req.params[:action]
    Autopoet.Window.control(String.to_existing_atom(to_string(action)))
    {200, "text/plain; charset=utf-8", "ok\n"}
  end

  def chat_transcript(req) do
    case Autopoet.Chat.transcript(req.query["id"] || "") do
      {:ok, body} -> {200, "text/plain; charset=utf-8", body}
      _ -> {404, %{error: "no such chat"}}
    end
  end

  def proposal_accept(req) do
    id = req.params["id"] || req.params[:id]

    case Autopoet.Proposals.accept(id, Autopoet.Notes.dir()) do
      :ok ->
        for {rel, _} <- Autopoet.Proposals.changes(id) do
          with {:ok, content} <- File.read(Path.join(Autopoet.Notes.dir(), rel)),
               do: Autopoet.Notes.write(rel, content)
        end

        %{ok: true}

      _ ->
        {404, %{error: "no such proposal"}}
    end
  end

  def proposal_reject(req) do
    Autopoet.Proposals.reject(req.params["id"] || req.params[:id])
    %{ok: true}
  end

  def cloud_status(_req) do
    signed = Autopoet.Cloud.signed_in?()
    acct = signed && Autopoet.Cloud.account()

    %{
      signed_in: signed,
      account: acct && %{email: acct.email, org: acct.org, role: acct.role},
      tools: Autopoet.Composio.configured?()
    }
  end

  def cloud_machine(_req) do
    case Autopoet.Cloud.get("/api/cloud/machine") do
      {:ok, b} -> b
      {:error, {_code, b}} when is_map(b) -> b
      {:error, :not_signed_in} -> %{"error" => "not signed in"}
      _ -> %{"error" => "unavailable"}
    end
  end
end

## Auth + power (cloud proxy)

server :power do
  route "POST /auth/signin", :signin, auth: :public
  route "POST /auth/oauth/:provider", :oauth, auth: :public
  route "POST /auth/connect/:provider", :connect, auth: :public
  route "POST /auth/disconnect/:provider", :disconnect, auth: :public
  route "GET /auth/providers.json", :providers, auth: :public
  route "POST /auth/signout", :signout, auth: :public
  route "GET /power/cloud/nexuses", :cloud_nexuses, auth: :public
  route "GET /power/cloud/tiers", :cloud_tiers, auth: :public
  route "GET /power/cloud/summary", :cloud_summary, auth: :public
  route "POST /power/cloud/checkout", :cloud_checkout, auth: :public
  route "POST /power/cloud/credits", :cloud_credits, auth: :public
  route "POST /power/compute", :power_compute, auth: :public

  defp prov(req), do: req.params["provider"] || req.params[:provider]
  defp txt(s), do: {200, "text/plain; charset=utf-8", s}

  defp cloud_proxy(method, path, body) do
    result = if method == :get, do: Autopoet.Cloud.get(path), else: Autopoet.Cloud.post(path, body)

    case result do
      {:ok, b} -> b
      {:error, {code, b}} when is_integer(code) and is_map(b) -> {code, b}
      {:error, :not_signed_in} -> {401, %{error: "not signed in"}}
      _ -> {502, %{error: "cloud unavailable"}}
    end
  end

  def signin(req) do
    case Autopoet.Auth.signin(req.query) do
      {:error, reason} -> txt("refused: #{inspect(reason)}\n")
      _ -> txt("app\n")
    end
  end

  def oauth(req) do
    case Autopoet.Auth.oauth(prov(req), req.query) do
      {:error, reason} -> txt("refused: #{inspect(reason)}\n")
      %{onboarded: true} -> txt("app\n")
      _ -> txt("onboarding\n")
    end
  end

  def connect(req) do
    case Autopoet.Auth.connect(prov(req)) do
      {:error, reason} -> txt("refused: #{inspect(reason)}\n")
      _ -> txt("ok\n")
    end
  end

  def disconnect(req) do
    Autopoet.Connections.delete(prov(req))
    Autopoet.Auth.disconnect(prov(req))
    txt("ok\n")
  end

  def providers(_req), do: %{configured: Autopoet.Auth.OAuth.configured(), connected: Autopoet.Connections.all()}
  def signout(_req), do: (Autopoet.Auth.signout(); txt("out\n"))

  def cloud_nexuses(_req), do: cloud_proxy(:get, "/api/platform/nexuses", nil)
  def cloud_tiers(_req), do: cloud_proxy(:get, "/api/platform/tiers", nil)

  def cloud_summary(_req) do
    %{
      credits: (case cloud_proxy(:get, "/api/platform/credits", nil) do %{} = m -> m; _ -> %{} end),
      subscription: (case cloud_proxy(:get, "/api/platform/billing/subscription", nil) do %{} = m -> m; _ -> %{} end)
    }
  end

  def cloud_checkout(req), do: cloud_proxy(:post, "/api/platform/billing/checkout", req.body)
  def cloud_credits(req), do: cloud_proxy(:post, "/api/platform/billing/credits", req.body)

  def power_compute(req) do
    choice = to_string(req.raw_body || "") |> String.trim() |> String.slice(0, 120)

    if choice == "" do
      {422, %{error: "compute choice required"}}
    else
      File.write!(Path.join([Autopoet.Discovery.home(), "data", "power-compute"]), choice)
      %{ok: true, compute: choice}
    end
  end
end

## Vault edits + voice brain + proposals

server :vault_edit do
  route "POST /notes/new", :notes_new, auth: :public
  route "POST /notes/delete", :notes_delete, auth: :public
  route "POST /notes/rename", :notes_rename, auth: :public
  route "POST /notes/reorder", :notes_reorder, auth: :public
  route "POST /notes/meta", :notes_meta, auth: :public
  route "POST /body/undo", :body_undo, auth: :public
  route "POST /body/redo", :body_redo, auth: :public
  route "GET /body/undostate.json", :body_undostate, auth: :public
  route "GET /body/history.json", :body_history, auth: :public
  route "POST /voice/brain", :voice_brain, auth: :public
  route "GET /proposals", :proposals, auth: :public
  route "GET /cloud/connections.json", :cloud_connections, auth: :public

  defp tags(s), do: (s || "") |> String.split(",", trim: true) |> Enum.map(&String.trim/1)
  defp meta_of(q), do: %{"type" => q["type"], "icon" => q["icon"], "tags" => tags(q["tags"])}
  defp undo_state, do: %{undo: Autopoet.Body.can_undo?(), redo: Autopoet.Body.can_redo?()}

  def notes_new(req) do
    q = req.query
    Autopoet.Notes.create(q["path"], q["type"], meta_of(q))
    {200, "text/plain; charset=utf-8", "created\n"}
  end

  def notes_delete(req) do
    case Autopoet.Notes.delete(req.query["path"]) do
      :ok -> {200, "text/plain; charset=utf-8", "deleted\n"}
      {:error, r} -> {200, "text/plain; charset=utf-8", "refused: #{inspect(r)}\n"}
    end
  end

  def notes_rename(req) do
    case Autopoet.Notes.rename(req.query["from"], req.query["to"]) do
      :ok -> {200, "text/plain; charset=utf-8", "renamed\n"}
      {:error, r} -> {200, "text/plain; charset=utf-8", "refused: #{inspect(r)}\n"}
    end
  end

  def notes_reorder(req) do
    names = String.split(req.query["names"] || "", "\n", trim: true)
    Autopoet.Notes.reorder(req.query["dir"] || "", names)
    {200, "text/plain; charset=utf-8", "reordered\n"}
  end

  def notes_meta(req) do
    Autopoet.Notes.set_meta(req.query["path"], meta_of(req.query))
    {200, "text/plain; charset=utf-8", "ok\n"}
  end

  def body_undo(req) do
    Autopoet.Body.undo(req.query["id"] || :latest)
    undo_state()
  end

  def body_redo(_req) do
    Autopoet.Body.redo()
    undo_state()
  end

  def body_undostate(_req), do: undo_state()
  def body_history(_req), do: {200, "application/json", Jason.encode!(Autopoet.Body.history())}

  def voice_brain(req) do
    with %{"history" => history} when is_list(history) <- (req.body || %{}),
         {:ok, reply} <- Autopoet.VoiceBrain.reply(history) do
      %{reply: reply}
    else
      _ -> {400, %{error: "bad request"}}
    end
  end

  def proposals(_req) do
    body =
      case Autopoet.Proposals.list() do
        [] -> "no proposals\n"
        ps -> Enum.map_join(ps, "\n", fn {id, status} -> "#{id} #{status}" end) <> "\n"
      end

    {200, "text/plain; charset=utf-8", body}
  end

  def cloud_connections(_req) do
    case Autopoet.Composio.connections() do
      {:ok, b} -> b
      _ -> %{"items" => []}
    end
  end
end

## Plan judge, profile, projects, cloud connect

server :ops do
  route "POST /plan/judge", :plan_judge, auth: :public
  route "POST /profile/set", :profile_set, auth: :public
  route "GET /projects", :projects_list, auth: :public
  route "GET /projects/:slug/status", :project_status, auth: :public
  route "POST /cloud/connect/:toolkit", :cloud_connect, auth: :public
  route "POST /cloud/deploy", :cloud_deploy, auth: :public

  def plan_judge(req) do
    case Autopoet.PlanBrain.judge(if(is_map(req.body), do: req.body, else: %{})) do
      {:ok, scores} -> scores
      _ -> {503, %{error: "judge unavailable"}}
    end
  end

  def profile_set(req) do
    case Autopoet.Profile.put(req.query["key"], req.query["value"]) do
      :ok -> {200, "text/plain; charset=utf-8", "ok\n"}
      _ -> {200, "text/plain; charset=utf-8", "refused: bad answer\n"}
    end
  end

  def projects_list(_req) do
    body =
      case Autopoet.Projects.list() do
        [] -> "no projects\n"
        ps -> Enum.map_join(ps, "\n", fn {slug, p} -> "#{slug} #{p.status} archetype=#{p.archetype}" end) <> "\n"
      end

    {200, "text/plain; charset=utf-8", body}
  end

  def project_status(req) do
    slug = req.params["slug"] || req.params[:slug]

    case Autopoet.Projects.get(slug) do
      nil ->
        {200, "text/plain; charset=utf-8", "unknown project\n"}

      _p ->
        hb = Path.join(Autopoet.Projects.artifacts_dir(slug), "state.txt")
        state = case File.read(hb) do {:ok, t} -> t; _ -> "(no heartbeat yet)\n" end
        {200, "text/plain; charset=utf-8", state}
    end
  end

  def cloud_connect(req) do
    toolkit = req.params["toolkit"] || req.params[:toolkit]

    case Autopoet.Composio.connect(toolkit) do
      {:ok, %{redirect_url: url}} -> {200, "text/plain; charset=utf-8", url}
      _ -> {503, %{error: "composio not configured"}}
    end
  end

  def cloud_deploy(_req) do
    case Autopoet.Cloud.post("/api/cloud/provision", %{}) do
      {:ok, body} -> body
      {:error, {code, b}} when is_integer(code) and is_map(b) -> {code, b}
      _ -> {502, %{error: "provision failed"}}
    end
  end
end

## Dev control + voice status

server :dev do
  route "POST /arm", :arm, auth: :public
  route "POST /disarm", :disarm, auth: :public
  route "POST /cycle", :cycle, auth: :public
  route "POST /kill", :kill, auth: :public
  route "POST /close", :close, auth: :public
  route "GET /voice/status", :voice_status, auth: :public
  route "GET /voice/sync.json", :voice_sync, auth: :public
  route "GET /voices/roster", :voices_roster, auth: :public
  route "POST /power/openrouter", :openrouter, auth: :public

  def arm(req) do
    every = req.query["every"] || "15m"
    Nexus.Autopoet.Worker.arm(every)
    {200, "text/plain; charset=utf-8", "armed every #{every}\n"}
  end

  def disarm(_req) do
    Nexus.Autopoet.Worker.disarm()
    {200, "text/plain; charset=utf-8", "disarmed\n"}
  end

  def cycle(_req) do
    report = Autopoet.Brain.cycle()
    {200, "text/plain; charset=utf-8", "cycle: sensed #{report.sensed}, results #{inspect(Enum.map(report.results, & &1.action))}\n"}
  end

  def kill(_req) do
    spawn(fn -> Process.sleep(150); :init.stop() end)
    {200, "text/plain; charset=utf-8", "halting\n"}
  end

  def close(_req) do
    case Process.whereis(Autopoet.Window) do
      nil -> {200, "text/plain; charset=utf-8", "no window (headless)\n"}
      _ -> Autopoet.Window.control(:close); {200, "text/plain; charset=utf-8", "closing\n"}
    end
  end

  def voice_status(_req), do: {200, "text/plain; charset=utf-8", to_string(Autopoet.Voice.status()) <> "\n"}
  def voice_sync(_req), do: {200, "application/json", Jason.encode!(Autopoet.Voice.sync())}
  def voices_roster(_req), do: {200, "text/html; charset=utf-8", Autopoet.VoiceRoster.html(Autopoet.Discovery.token())}

  def openrouter(req) do
    key = to_string(req.raw_body || "") |> String.trim()

    if key == "" do
      {422, %{error: "empty key"}}
    else
      Autopoet.Keys.set_openrouter(key)
      %{ok: true}
    end
  end
end
