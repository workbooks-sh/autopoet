# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
autopoet-*.tar

/data/
.DS_Store
.env
/compilers
/kits
.claude/worktrees/
history/
eval/live-runs/

# runtime artifacts — re-created on boot or by the desk; never source
.wrangler/
/archive/
/eval/desk/
/eval/desks/
/eval/venture/
/guide/skill--*.work

# model weights — never commit (downloaded to disk)
desktop_ml/models/
*.gguf
app/home/static/

# native NIF build artifact (rebuilt from c_src/ by elixir_make on macOS desktop)
/priv/*.so

# desktop packaging artifacts — the assembled .app/.dmg (scripts/package-macos.sh)
/dist/

# runtime Store DB + learned-knowledge log — recreated on boot; never source (was tracked, see review-hardening)
.nexus/

# stale hand-committed .app stub (execs a hardcoded path); the real bundle is built into dist/ by scripts/package-macos.sh
/Autopoet.app/
